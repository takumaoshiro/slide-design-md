---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
const mdPath = path.resolve('..', 'designs', 'netflix', 'DESIGN.md');
const mdRaw = fs.readFileSync(mdPath, 'utf-8');
const mdHtml = await marked(mdRaw);
---

<Layout title="Netflix — slide-design-md">
  <nav>
    <div class="nav-inner">
      <a href="/slide-design-md/" class="nav-back">&larr; Back to designs</a>
      <a href="https://github.com/takumaoshiro/slide-design-md" class="nav-gh" target="_blank">GitHub</a>
    </div>
  </nav>

  <!-- Header -->
  <section class="detail-header">
    <div class="container">
      <h1>Netflix</h1>
      <p class="detail-tagline">Dark entertainment. Cinematic black, red accent, content showcase. Data-informed storytelling.</p>
    </div>
  </section>

  <!-- Usage -->
  <section class="usage">
    <div class="container">
      <div class="usage-grid">
        <div class="usage-cmd">
          <div class="cmd-box">
            <code>curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/netflix/DESIGN.md</code>
            <button class="copy-btn" data-copy="curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/netflix/DESIGN.md" title="Copy">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
          <p class="cmd-help">Run from your project root, then ask your AI assistant to use DESIGN.md for slide generation.</p>
        </div>
        <div class="usage-info">
          <span class="info-badge">16:9</span>
          <span class="info-badge">Netflix Sans / Helvetica Neue</span>
          <span class="info-badge">Entertainment</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Preview tabs -->
  <section class="preview-section">
    <div class="container">
      <div class="tabs-bar">
        <h2>Preview</h2>
        <div class="tabs">
          <button class="tab active" data-tab="preview">Slide Preview</button>
          <button class="tab" data-tab="designmd">DESIGN.md</button>
        </div>
      </div>

      <!-- Slide Preview -->
      <div id="tab-preview" class="tab-content active">
        <div class="slides-grid">

          <!-- Cover Slide -->
          <div class="slide-label">01 — Cover</div>
          <div class="slide-frame">
            <div class="s nf-s">
              <div class="nf-line"></div>
              <div class="nf-body center">
                <div class="nf-logo-text">NETFLIX</div>
                <div class="nf-h0">Content Performance Review</div>
                <div class="nf-sep"></div>
                <div class="nf-sub0">Q1 2025 — Global Originals Team</div>
              </div>
            </div>
          </div>

          <!-- Content Slide -->
          <div class="slide-label">02 — Content</div>
          <div class="slide-frame">
            <div class="s nf-s">
              <div class="nf-line"></div>
              <div class="nf-inner">
                <div class="nf-h1">Audience Engagement Insights</div>
                <div class="nf-sub1">Key takeaways from Q1 viewing patterns</div>
                <div class="nf-cols">
                  <div class="nf-card">
                    <div class="nf-card-bar" style="background:#E50914;"></div>
                    <div class="nf-card-inner">
                      <div class="nf-card-title">Binge Completion Rate Up</div>
                      <div class="nf-card-text">Series completion within 7 days increased 18% vs. prior quarter</div>
                    </div>
                  </div>
                  <div class="nf-card">
                    <div class="nf-card-bar" style="background:#46D369;"></div>
                    <div class="nf-card-inner">
                      <div class="nf-card-title">International Growth</div>
                      <div class="nf-card-text">Non-English originals now account for 34% of total viewing hours</div>
                    </div>
                  </div>
                </div>
                <div class="nf-footer-text">NETFLIX</div>
              </div>
            </div>
          </div>

          <!-- Data Slide -->
          <div class="slide-label">03 — Data / Table</div>
          <div class="slide-frame">
            <div class="s nf-s">
              <div class="nf-line"></div>
              <div class="nf-inner">
                <div class="nf-h1">Top Titles by Viewing Hours</div>
                <div class="nf-sub1">Q1 2025 — First 28 days</div>
                <table class="nf-table">
                  <thead>
                    <tr>
                      <th>Title</th><th>Genre</th><th>Hours (M)</th><th>Completion</th><th>vs. Prev</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr><td>Glass Onion 2</td><td>Thriller</td><td>124.5</td><td>89%</td><td style="color:#46D369;">+22%</td></tr>
                    <tr><td>Stranger Things S5</td><td>Sci-Fi</td><td>112.3</td><td>94%</td><td style="color:#46D369;">+45%</td></tr>
                    <tr><td>The Crown S7</td><td>Drama</td><td>86.1</td><td>78%</td><td style="color:#F5A623;">+2%</td></tr>
                    <tr><td>Squid Game S3</td><td>Thriller</td><td>201.7</td><td>91%</td><td style="color:#46D369;">+31%</td></tr>
                  </tbody>
                </table>
                <div class="nf-footer-text">NETFLIX</div>
              </div>
            </div>
          </div>

          <!-- KPI Slide -->
          <div class="slide-label">04 — KPI Dashboard</div>
          <div class="slide-frame">
            <div class="s nf-s">
              <div class="nf-line"></div>
              <div class="nf-inner">
                <div class="nf-h1">Q1 Performance Snapshot</div>
                <div class="nf-sub1">Global streaming metrics</div>
                <div class="nf-kpis">
                  <div class="nf-kpi nf-kpi-primary">
                    <div class="nf-kpi-num" style="color:#E50914;">283M</div>
                    <div class="nf-kpi-label">Global Subscribers</div>
                  </div>
                  <div class="nf-kpi">
                    <div class="nf-kpi-num" style="color:#46D369;">+8.2%</div>
                    <div class="nf-kpi-label">YoY Growth</div>
                  </div>
                  <div class="nf-kpi">
                    <div class="nf-kpi-num" style="color:#FFFFFF;">2.1h</div>
                    <div class="nf-kpi-label">Avg. Daily View Time</div>
                  </div>
                  <div class="nf-kpi">
                    <div class="nf-kpi-num" style="color:#46D369;">94.2%</div>
                    <div class="nf-kpi-label">Retention Rate</div>
                  </div>
                </div>
                <div class="nf-footer-text">NETFLIX</div>
              </div>
            </div>
          </div>

          <!-- Color Palette -->
          <div class="slide-label">05 — Color Palette</div>
          <div class="slide-frame">
            <div class="s nf-s">
              <div class="nf-line"></div>
              <div class="nf-inner">
                <div class="nf-h1">Color Palette</div>
                <div class="nf-palette">
                  <div class="nf-swatch"><div class="swatch-block" style="background:#E50914;"></div><div class="swatch-name">Netflix Red<br/>#E50914</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#000000;"></div><div class="swatch-name">Black<br/>#000000</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#141414;"></div><div class="swatch-name">Dark<br/>#141414</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#1F1F1F;"></div><div class="swatch-name">Card<br/>#1F1F1F</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#2A2A2A;"></div><div class="swatch-name">Hover<br/>#2A2A2A</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#FFFFFF; border: 1px solid #333;"></div><div class="swatch-name">White<br/>#FFFFFF</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#E5E5E5;"></div><div class="swatch-name">Light<br/>#E5E5E5</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#808080;"></div><div class="swatch-name">Muted<br/>#808080</div></div>
                  <div class="nf-swatch"><div class="swatch-block" style="background:#46D369;"></div><div class="swatch-name">Green<br/>#46D369</div></div>
                </div>
                <div class="nf-footer-text">NETFLIX</div>
              </div>
            </div>
          </div>

          <!-- Typography -->
          <div class="slide-label">06 — Typography</div>
          <div class="slide-frame">
            <div class="s nf-s">
              <div class="nf-line"></div>
              <div class="nf-inner">
                <div class="nf-h1">Typography Scale</div>
                <div class="nf-type-samples">
                  <div class="nf-type-row">
                    <span class="nf-type-demo" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;font-weight:700;color:#FFFFFF;">Slide Title — 32pt Bold</span>
                    <span class="nf-type-meta">Bold · #FFFFFF</span>
                  </div>
                  <div class="nf-type-row">
                    <span class="nf-type-demo" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:11px;font-weight:700;color:#E50914;">Section Heading — 18pt Bold</span>
                    <span class="nf-type-meta">Bold · Netflix Red</span>
                  </div>
                  <div class="nf-type-row">
                    <span class="nf-type-demo" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:9px;color:#E5E5E5;">Body text — 12pt Regular. Standard reading size for content slides.</span>
                    <span class="nf-type-meta">Regular · #E5E5E5</span>
                  </div>
                  <div class="nf-type-row">
                    <span class="nf-type-demo" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:9px;color:#808080;">Subtitle — 14pt Regular</span>
                    <span class="nf-type-meta">Regular · #808080</span>
                  </div>
                  <div class="nf-type-row">
                    <span class="nf-type-demo" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:7px;color:#808080;">Caption / Note — 9pt Regular</span>
                    <span class="nf-type-meta">Regular · #808080</span>
                  </div>
                </div>
                <div class="nf-footer-text">NETFLIX</div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- DESIGN.md tab -->
      <div id="tab-designmd" class="tab-content">
        <div class="md-frame">
          <div class="md-toolbar">
            <button class="copy-md-btn" id="copy-md">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
              <span>Copy DESIGN.md</span>
            </button>
          </div>
          <div class="md-body" set:html={mdHtml} />
        </div>
        <textarea id="md-raw" style="display:none;">{mdRaw}</textarea>
      </div>

    </div>
  </section>

  <footer>
    <div class="container">
      <p>slide-design-md &mdash; Built for AI agents that create presentations.</p>
    </div>
  </footer>
</Layout>

<style>
  nav { position: sticky; top: 0; z-index: 100; background: rgba(0,0,0,0.8); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); height: 48px; }
  .nav-inner { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; height: 100%; display: flex; align-items: center; justify-content: space-between; }
  .nav-back { font-size: 14px; color: #2997ff; letter-spacing: -0.224px; }
  .nav-back:hover { text-decoration: underline; }
  .nav-gh { font-size: 12px; color: #f5f5f7; opacity: 0.8; }
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; }

  .detail-header { background: var(--black); padding: 3rem 0 2.5rem; }
  .detail-header h1 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 40px; font-weight: 600; color: var(--white); line-height: 1.1; letter-spacing: -0.5px; margin-bottom: 0.5rem; }
  .detail-tagline { font-size: 17px; color: rgba(255,255,255,0.55); letter-spacing: -0.374px; }

  .usage { background: var(--black); padding: 0 0 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .usage-grid { display: flex; gap: 2rem; align-items: flex-start; }
  .usage-cmd { flex: 1; }
  .cmd-box { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; gap: 12px; position: relative; }
  .cmd-box code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; color: #e0e0e0; word-break: break-all; flex: 1; }
  .copy-btn { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 4px; transition: color 0.2s; flex-shrink: 0; }
  .copy-btn:hover { color: var(--white); }
  .cmd-help { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 0.5rem; letter-spacing: -0.12px; }
  .usage-info { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 4px; }
  .info-badge { font-size: 12px; color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.15); border-radius: 4px; padding: 4px 10px; letter-spacing: -0.12px; }

  .preview-section { background: var(--light-bg); padding: 3rem 0 4rem; }
  .tabs-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .tabs-bar h2 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 28px; font-weight: 600; color: var(--near-black); }
  .tabs { display: flex; border: 1px solid rgba(0,0,0,0.15); border-radius: 8px; overflow: hidden; }
  .tab { padding: 6px 18px; font-size: 14px; font-family: inherit; letter-spacing: -0.224px; border: none; background: transparent; color: var(--text-80); cursor: pointer; transition: all 0.2s; }
  .tab.active { background: var(--near-black); color: var(--white); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* Slides grid */
  .slides-grid { display: flex; flex-direction: column; gap: 1rem; }
  .slide-label { font-size: 12px; font-weight: 600; color: var(--text-48); letter-spacing: 0.5px; text-transform: uppercase; margin-top: 1rem; }
  .slide-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }

  /* Base slide */
  .s { width: 100%; aspect-ratio: 16/9; position: relative; overflow: hidden; }
  .nf-s { background: #141414; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }
  .nf-line { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: #E50914; }

  /* Cover */
  .nf-body.center { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 8%; gap: 3%; }
  .nf-logo-text { font-size: clamp(8px, 1.4vw, 16px); font-weight: 700; color: #E50914; letter-spacing: 3px; }
  .nf-h0 { font-size: clamp(14px, 3.2vw, 44px); font-weight: 700; color: #FFFFFF; text-align: center; }
  .nf-sep { width: 8%; height: 2px; background: #E50914; }
  .nf-sub0 { font-size: clamp(7px, 1.1vw, 14px); color: #808080; }

  /* Inner layout */
  .nf-inner { padding: 5% 6% 4%; height: 100%; display: flex; flex-direction: column; margin-top: 3px; }
  .nf-h1 { font-size: clamp(10px, 2.2vw, 32px); font-weight: 700; color: #FFFFFF; }
  .nf-sub1 { font-size: clamp(6px, 1vw, 14px); color: #808080; margin-top: 1%; margin-bottom: 3%; }
  .nf-footer-text { margin-top: auto; text-align: right; font-size: clamp(5px, 0.8vw, 8px); color: #808080; letter-spacing: 1px; }

  /* Cards */
  .nf-cols { display: flex; gap: 3%; flex: 1; }
  .nf-card { flex: 1; background: #1F1F1F; display: flex; border-radius: 4px; overflow: hidden; }
  .nf-card-bar { width: 4px; flex-shrink: 0; }
  .nf-card-inner { padding: 3% 4%; }
  .nf-card-title { font-size: clamp(6px, 1.1vw, 13px); font-weight: 700; color: #FFFFFF; margin-bottom: 2%; }
  .nf-card-text { font-size: clamp(5px, 0.85vw, 10px); color: #E5E5E5; line-height: 1.4; }

  /* Table */
  .nf-table { width: 100%; border-collapse: collapse; flex: 1; }
  .nf-table th { background: #E50914; color: #FFFFFF; font-size: clamp(5px, 0.85vw, 10px); font-weight: 700; padding: 1.5% 2%; text-align: left; }
  .nf-table td { font-size: clamp(5px, 0.85vw, 10px); color: #E5E5E5; padding: 1.5% 2%; border-bottom: 1px solid #2A2A2A; }
  .nf-table tbody tr:nth-child(odd) { background: #1F1F1F; }
  .nf-table tbody tr:nth-child(even) { background: #141414; }

  /* KPI */
  .nf-kpis { display: flex; gap: 2.5%; margin-top: 2%; flex: 1; }
  .nf-kpi { flex: 1; background: #1F1F1F; border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2%; }
  .nf-kpi-primary { border-top: 3px solid #E50914; }
  .nf-kpi-num { font-size: clamp(10px, 2.2vw, 28px); font-weight: 700; }
  .nf-kpi-label { font-size: clamp(5px, 0.8vw, 10px); margin-top: 2%; color: #808080; }

  /* Palette */
  .nf-palette { display: flex; flex-wrap: wrap; gap: 2%; margin-top: 3%; }
  .nf-swatch { display: flex; flex-direction: column; align-items: center; width: 9%; }
  .swatch-block { width: 100%; aspect-ratio: 1; border-radius: 4px; }
  .swatch-name { font-size: clamp(4px, 0.6vw, 7px); color: #E5E5E5; text-align: center; margin-top: 4px; line-height: 1.3; }

  /* Typography */
  .nf-type-samples { display: flex; flex-direction: column; gap: 3%; margin-top: 3%; flex: 1; }
  .nf-type-row { display: flex; justify-content: space-between; align-items: baseline; padding: 1.5% 0; border-bottom: 1px solid #1F1F1F; }
  .nf-type-demo { flex: 1; }
  .nf-type-meta { font-size: clamp(4px, 0.6vw, 7px); color: #808080; flex-shrink: 0; margin-left: 4%; }

  /* DESIGN.md frame */
  .md-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; background: #fff; padding: 0 2.5rem 2rem; }
  .md-toolbar { display: flex; justify-content: flex-end; padding: 1rem 0; position: sticky; top: 48px; background: #fff; z-index: 10; border-bottom: 1px solid #e5e7f0; }
  .copy-md-btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(0,0,0,0.15); background: #fff; color: var(--near-black); font-size: 13px; font-family: inherit; letter-spacing: -0.12px; cursor: pointer; transition: all 0.2s; }
  .copy-md-btn:hover { background: var(--light-bg); border-color: rgba(0,0,0,0.3); }
  .copy-md-btn.copied { background: #e8f5e9; border-color: #2e7d32; color: #2e7d32; }
  .md-body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif; font-size: 15px; color: #1d1d1f; line-height: 1.6; }
  .md-body h1 { font-size: 28px; font-weight: 600; margin: 2rem 0 1rem; color: #1d1d1f; border-bottom: 1px solid #e5e7f0; padding-bottom: 0.5rem; }
  .md-body h2 { font-size: 22px; font-weight: 600; margin: 2rem 0 0.75rem; color: #1d1d1f; }
  .md-body h3 { font-size: 17px; font-weight: 600; margin: 1.5rem 0 0.5rem; color: #1d1d1f; }
  .md-body p { margin: 0.75rem 0; }
  .md-body ul, .md-body ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .md-body li { margin: 0.25rem 0; }
  .md-body code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; background: #f5f5f7; padding: 2px 6px; border-radius: 4px; }
  .md-body pre { background: #1d1d1f; color: #e0e0e0; padding: 1rem 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
  .md-body pre code { background: none; padding: 0; color: inherit; font-size: 13px; }
  .md-body table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 14px; }
  .md-body th { text-align: left; font-weight: 600; padding: 8px 12px; border-bottom: 2px solid #e5e7f0; }
  .md-body td { padding: 8px 12px; border-bottom: 1px solid #e5e7f0; }
  .md-body hr { border: none; border-top: 1px solid #e5e7f0; margin: 2rem 0; }
  .md-body strong { font-weight: 600; }
  .md-body blockquote { border-left: 3px solid #0071e3; margin: 1rem 0; padding: 0.5rem 1rem; background: #f5f5f7; border-radius: 0 4px 4px 0; }

  footer { background: var(--light-bg); padding: 2rem 0; text-align: center; border-top: 1px solid rgba(0,0,0,0.06); }
  footer p { font-size: 12px; color: var(--text-48); }

  @media (max-width: 834px) {
    .usage-grid { flex-direction: column; }
    .detail-header h1 { font-size: 32px; }
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const target = (btn as HTMLElement).dataset.tab;
      document.getElementById('tab-' + target)?.classList.add('active');
    });
  });
  // Copy command button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text);
      btn.innerHTML = '<span style="font-size:12px;color:#2E7D32;">Copied!</span>';
      setTimeout(() => {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>';
      }, 1500);
    });
  });
  // Copy DESIGN.md
  document.getElementById('copy-md')?.addEventListener('click', () => {
    const raw = (document.getElementById('md-raw') as HTMLTextAreaElement)?.value || '';
    navigator.clipboard.writeText(raw);
    const btn = document.getElementById('copy-md')!;
    btn.classList.add('copied');
    btn.querySelector('span')!.textContent = 'Copied!';
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.querySelector('span')!.textContent = 'Copy DESIGN.md';
    }, 2000);
  });
</script>

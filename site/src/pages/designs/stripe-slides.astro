---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
const mdPath = path.resolve('..', 'designs', 'stripe-slides', 'DESIGN.md');
const mdRaw = fs.readFileSync(mdPath, 'utf-8');
const mdHtml = await marked(mdRaw);
---

<Layout title="Stripe (Slides) — slide-design-md">
  <nav>
    <div class="nav-inner">
      <a href="/slide-design-md/" class="nav-back">&larr; Back to designs</a>
      <a href="https://github.com/takumaoshiro/slide-design-md" class="nav-gh" target="_blank">GitHub</a>
    </div>
  </nav>

  <!-- Header -->
  <section class="detail-header">
    <div class="container">
      <h1>Stripe (Slides)</h1>
      <p class="detail-tagline">Developer-elegant presentation. Purple gradient, clean data, technical sophistication.</p>
    </div>
  </section>

  <!-- Usage -->
  <section class="usage">
    <div class="container">
      <div class="usage-grid">
        <div class="usage-cmd">
          <div class="cmd-box">
            <code>curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/stripe-slides/DESIGN.md</code>
            <button class="copy-btn" data-copy="curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/stripe-slides/DESIGN.md" title="Copy">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
          <p class="cmd-help">Run from your project root, then ask your AI assistant to use DESIGN.md for slide generation.</p>
        </div>
        <div class="usage-info">
          <span class="info-badge">16:9</span>
          <span class="info-badge">Inter / Source Code Pro</span>
          <span class="info-badge">Developer / Fintech</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Preview tabs -->
  <section class="preview-section">
    <div class="container">
      <div class="tabs-bar">
        <h2>Preview</h2>
        <div class="tabs">
          <button class="tab active" data-tab="preview">Slide Preview</button>
          <button class="tab" data-tab="designmd">DESIGN.md</button>
        </div>
      </div>

      <!-- Slide Preview -->
      <div id="tab-preview" class="tab-content active">
        <div class="slides-grid">

          <!-- Cover Slide -->
          <div class="slide-label">01 — Cover</div>
          <div class="slide-frame">
            <div class="s st-s st-dark">
              <div class="st-bar"></div>
              <div class="st-cover">
                <div class="st-eyebrow">STRIPE</div>
                <div class="st-hero">Payments infrastructure<br/>for the internet</div>
                <div class="st-hero-sub">Developer tools, APIs, and platform for global commerce</div>
              </div>
            </div>
          </div>

          <!-- Content Slide -->
          <div class="slide-label">02 — Content</div>
          <div class="slide-frame">
            <div class="s st-s st-light">
              <div class="st-bar"></div>
              <div class="st-inner">
                <div class="st-eyebrow-sm">INTEGRATION</div>
                <div class="st-title">Accept payments in minutes</div>
                <div class="st-cols">
                  <div class="st-col-text">
                    <div class="st-body">A single integration handles cards, wallets, bank transfers, and 135+ currencies. Start with a few lines of code.</div>
                  </div>
                  <div class="st-col-code">
                    <div class="st-code-block">
                      <div class="st-code-line"><span class="st-kw">const</span> stripe = <span class="st-fn">require</span>(<span class="st-str">'stripe'</span>);</div>
                      <div class="st-code-line">&nbsp;</div>
                      <div class="st-code-line"><span class="st-kw">const</span> payment = <span class="st-kw">await</span></div>
                      <div class="st-code-line">&nbsp; stripe.paymentIntents.<span class="st-fn">create</span>({"{"}</div>
                      <div class="st-code-line">&nbsp; &nbsp; amount: <span class="st-num">2000</span>,</div>
                      <div class="st-code-line">&nbsp; &nbsp; currency: <span class="st-str">'usd'</span>,</div>
                      <div class="st-code-line">&nbsp; {"}"});</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Data Slide -->
          <div class="slide-label">03 — Data / Table</div>
          <div class="slide-frame">
            <div class="s st-s st-light">
              <div class="st-bar"></div>
              <div class="st-inner">
                <div class="st-eyebrow-sm">PERFORMANCE</div>
                <div class="st-title">Platform metrics — Q4 2024</div>
                <table class="st-table">
                  <thead>
                    <tr>
                      <th>Metric</th><th>Value</th><th>QoQ Change</th><th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr><td>Payment Volume</td><td>$245B</td><td style="color:#00D4AA;">+18%</td><td><span class="st-badge st-badge-green">On track</span></td></tr>
                    <tr class="st-row-alt"><td>API Uptime</td><td>99.999%</td><td style="color:#00D4AA;">+0.001%</td><td><span class="st-badge st-badge-green">Healthy</span></td></tr>
                    <tr><td>Active Merchants</td><td>3.4M</td><td style="color:#00D4AA;">+12%</td><td><span class="st-badge st-badge-green">Growing</span></td></tr>
                    <tr class="st-row-alt"><td>Avg Latency</td><td>42ms</td><td style="color:#E25950;">+3ms</td><td><span class="st-badge st-badge-amber">Monitor</span></td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- KPI Slide -->
          <div class="slide-label">04 — KPI Dashboard</div>
          <div class="slide-frame">
            <div class="s st-s st-light">
              <div class="st-bar"></div>
              <div class="st-inner">
                <div class="st-eyebrow-sm">DASHBOARD</div>
                <div class="st-title">Key metrics at a glance</div>
                <div class="st-kpis">
                  <div class="st-kpi">
                    <div class="st-kpi-num">$245B</div>
                    <div class="st-kpi-label">Payment Volume</div>
                    <div class="st-kpi-trend st-up">+18% QoQ</div>
                  </div>
                  <div class="st-kpi">
                    <div class="st-kpi-num">3.4M</div>
                    <div class="st-kpi-label">Active Merchants</div>
                    <div class="st-kpi-trend st-up">+12% QoQ</div>
                  </div>
                  <div class="st-kpi">
                    <div class="st-kpi-num">99.999%</div>
                    <div class="st-kpi-label">API Uptime</div>
                    <div class="st-kpi-trend st-up">+0.001%</div>
                  </div>
                  <div class="st-kpi">
                    <div class="st-kpi-num" style="color:#30B85E;">135+</div>
                    <div class="st-kpi-label">Currencies</div>
                    <div class="st-kpi-trend" style="color:#425466;">Global</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Color Palette -->
          <div class="slide-label">05 — Color Palette</div>
          <div class="slide-frame">
            <div class="s st-s st-dark">
              <div class="st-bar"></div>
              <div class="st-inner">
                <div class="st-title" style="color:#FFFFFF;">Color Palette</div>
                <div class="st-palette">
                  <div class="st-swatch"><div class="swatch-block" style="background:linear-gradient(135deg,#635BFF,#7A73FF);"></div><div class="swatch-name">Purple<br/>#635BFF</div></div>
                  <div class="st-swatch"><div class="swatch-block" style="background:#0A2540;"></div><div class="swatch-name">Navy<br/>#0A2540</div></div>
                  <div class="st-swatch"><div class="swatch-block" style="background:#FFFFFF; border:1px solid #425466;"></div><div class="swatch-name">White<br/>#FFFFFF</div></div>
                  <div class="st-swatch"><div class="swatch-block" style="background:#425466;"></div><div class="swatch-name">Slate<br/>#425466</div></div>
                  <div class="st-swatch"><div class="swatch-block" style="background:#F6F9FC; border:1px solid #425466;"></div><div class="swatch-name">Light<br/>#F6F9FC</div></div>
                  <div class="st-swatch"><div class="swatch-block" style="background:#596980;"></div><div class="swatch-name">Body<br/>#596980</div></div>
                  <div class="st-swatch"><div class="swatch-block" style="background:#00D4AA;"></div><div class="swatch-name">Cyan<br/>#00D4AA</div></div>
                  <div class="st-swatch"><div class="swatch-block" style="background:#30B85E;"></div><div class="swatch-name">Green<br/>#30B85E</div></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Typography -->
          <div class="slide-label">06 — Typography</div>
          <div class="slide-frame">
            <div class="s st-s st-dark">
              <div class="st-bar"></div>
              <div class="st-inner">
                <div class="st-title" style="color:#FFFFFF;">Typography Scale</div>
                <div class="st-type-samples">
                  <div class="st-type-row">
                    <span class="st-type-demo" style="font-family:Inter,'Segoe UI',system-ui,sans-serif;font-size:clamp(14px,3vw,28px);font-weight:700;color:#FFFFFF;">Hero Title — 48pt Inter Bold</span>
                    <span class="st-type-meta">700 · #FFFFFF</span>
                  </div>
                  <div class="st-type-row">
                    <span class="st-type-demo" style="font-family:Inter,'Segoe UI',system-ui,sans-serif;font-size:clamp(8px,1.3vw,14px);font-weight:700;color:#635BFF;text-transform:uppercase;letter-spacing:1px;">Section Label — 12pt Inter Bold</span>
                    <span class="st-type-meta">700 · Purple</span>
                  </div>
                  <div class="st-type-row">
                    <span class="st-type-demo" style="font-family:Inter,'Segoe UI',system-ui,sans-serif;font-size:clamp(10px,2vw,20px);font-weight:600;color:#FFFFFF;">Slide Title — 36pt Inter Semibold</span>
                    <span class="st-type-meta">600 · Navy/White</span>
                  </div>
                  <div class="st-type-row">
                    <span class="st-type-demo" style="font-family:Inter,'Segoe UI',system-ui,sans-serif;font-size:clamp(7px,1vw,13px);font-weight:400;color:rgba(255,255,255,0.7);">Body text — 16pt Inter Regular. Clean and readable.</span>
                    <span class="st-type-meta">400 · #596980</span>
                  </div>
                  <div class="st-type-row">
                    <span class="st-type-demo" style="font-family:'Source Code Pro','Consolas',monospace;font-size:clamp(6px,0.9vw,12px);font-weight:400;color:#00D4AA;">const stripe = require('stripe'); <span style="color:#888;">// code</span></span>
                    <span class="st-type-meta">Source Code Pro</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- DESIGN.md tab -->
      <div id="tab-designmd" class="tab-content">
        <div class="md-frame">
          <div class="md-toolbar">
            <button class="copy-md-btn" id="copy-md">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
              <span>Copy DESIGN.md</span>
            </button>
          </div>
          <div class="md-body" set:html={mdHtml} />
        </div>
        <textarea id="md-raw" style="display:none;">{mdRaw}</textarea>
      </div>

    </div>
  </section>

  <footer>
    <div class="container">
      <p>slide-design-md &mdash; Built for AI agents that create presentations.</p>
    </div>
  </footer>
</Layout>

<style>
  nav { position: sticky; top: 0; z-index: 100; background: rgba(0,0,0,0.8); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); height: 48px; }
  .nav-inner { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; height: 100%; display: flex; align-items: center; justify-content: space-between; }
  .nav-back { font-size: 14px; color: #2997ff; letter-spacing: -0.224px; }
  .nav-back:hover { text-decoration: underline; }
  .nav-gh { font-size: 12px; color: #f5f5f7; opacity: 0.8; }
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; }

  .detail-header { background: var(--black); padding: 3rem 0 2.5rem; }
  .detail-header h1 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 40px; font-weight: 600; color: var(--white); line-height: 1.1; letter-spacing: -0.5px; margin-bottom: 0.5rem; }
  .detail-tagline { font-size: 17px; color: rgba(255,255,255,0.55); letter-spacing: -0.374px; }

  .usage { background: var(--black); padding: 0 0 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .usage-grid { display: flex; gap: 2rem; align-items: flex-start; }
  .usage-cmd { flex: 1; }
  .cmd-box { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; gap: 12px; position: relative; }
  .cmd-box code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; color: #e0e0e0; word-break: break-all; flex: 1; }
  .copy-btn { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 4px; transition: color 0.2s; flex-shrink: 0; }
  .copy-btn:hover { color: var(--white); }
  .cmd-help { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 0.5rem; letter-spacing: -0.12px; }
  .usage-info { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 4px; }
  .info-badge { font-size: 12px; color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.15); border-radius: 4px; padding: 4px 10px; letter-spacing: -0.12px; }

  .preview-section { background: var(--light-bg); padding: 3rem 0 4rem; }
  .tabs-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .tabs-bar h2 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 28px; font-weight: 600; color: var(--near-black); }
  .tabs { display: flex; border: 1px solid rgba(0,0,0,0.15); border-radius: 8px; overflow: hidden; }
  .tab { padding: 6px 18px; font-size: 14px; font-family: inherit; letter-spacing: -0.224px; border: none; background: transparent; color: var(--text-80); cursor: pointer; transition: all 0.2s; }
  .tab.active { background: var(--near-black); color: var(--white); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* Slides grid */
  .slides-grid { display: flex; flex-direction: column; gap: 1rem; }
  .slide-label { font-size: 12px; font-weight: 600; color: var(--text-48); letter-spacing: 0.5px; text-transform: uppercase; margin-top: 1rem; }
  .slide-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }

  /* Base slide */
  .s { width: 100%; aspect-ratio: 16/9; position: relative; overflow: hidden; }
  .st-s { font-family: Inter, 'Segoe UI', system-ui, sans-serif; }
  .st-dark { background: #0A2540; }
  .st-light { background: #FFFFFF; }
  .st-bar { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #635BFF, #7A73FF); z-index: 2; }

  /* Cover */
  .st-cover { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 8%; gap: 3%; }
  .st-eyebrow { font-size: clamp(7px, 1vw, 12px); font-weight: 700; color: #635BFF; letter-spacing: 2px; text-transform: uppercase; }
  .st-hero { font-size: clamp(14px, 3.2vw, 38px); font-weight: 700; color: #FFFFFF; text-align: center; line-height: 1.2; letter-spacing: -0.02em; }
  .st-hero-sub { font-size: clamp(7px, 1.1vw, 14px); font-weight: 400; color: rgba(255,255,255,0.6); text-align: center; max-width: 70%; }

  /* Inner layout */
  .st-inner { padding: 5% 7% 4%; height: 100%; display: flex; flex-direction: column; margin-top: 4px; }
  .st-eyebrow-sm { font-size: clamp(5px, 0.8vw, 10px); font-weight: 700; color: #635BFF; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 1%; }
  .st-title { font-size: clamp(10px, 2.2vw, 24px); font-weight: 600; color: #0A2540; margin-bottom: 3%; letter-spacing: -0.02em; }

  /* Content: text + code columns */
  .st-cols { display: flex; gap: 4%; flex: 1; align-items: flex-start; }
  .st-col-text { flex: 1; }
  .st-col-code { flex: 1.2; }
  .st-body { font-size: clamp(6px, 0.95vw, 12px); color: #596980; line-height: 1.6; }
  .st-code-block { background: #F6F9FC; border: 1px solid #E3E8EE; border-radius: 6px; padding: 3% 4%; font-family: 'Source Code Pro', 'Consolas', monospace; font-size: clamp(5px, 0.75vw, 10px); line-height: 1.7; color: #0A2540; }
  .st-code-line { white-space: pre; }
  .st-kw { color: #635BFF; }
  .st-fn { color: #0A2540; }
  .st-str { color: #00D4AA; }
  .st-num { color: #D97917; }

  /* Table */
  .st-table { width: 100%; border-collapse: collapse; margin-top: 1%; flex: 1; }
  .st-table th { font-size: clamp(5px, 0.8vw, 10px); font-weight: 600; color: #425466; padding: 1.5% 2%; text-align: left; border-bottom: 2px solid #E3E8EE; }
  .st-table td { font-size: clamp(5px, 0.8vw, 10px); color: #596980; padding: 1.5% 2%; border-bottom: 1px solid #E3E8EE; }
  .st-row-alt { background: #F6F9FC; }
  .st-badge { font-size: clamp(4px, 0.6vw, 8px); padding: 1px 6px; border-radius: 10px; font-weight: 600; }
  .st-badge-green { background: rgba(48,184,94,0.15); color: #30B85E; }
  .st-badge-amber { background: rgba(217,121,23,0.15); color: #D97917; }

  /* KPI */
  .st-kpis { display: flex; gap: 3%; margin-top: 2%; flex: 1; }
  .st-kpi { flex: 1; background: #F6F9FC; border: 1px solid #E3E8EE; border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3%; }
  .st-kpi-num { font-size: clamp(12px, 2.8vw, 30px); font-weight: 700; color: #635BFF; line-height: 1; }
  .st-kpi-label { font-size: clamp(5px, 0.75vw, 9px); color: #425466; margin-top: 4%; font-weight: 600; }
  .st-kpi-trend { font-size: clamp(4px, 0.6vw, 8px); margin-top: 3%; font-weight: 600; }
  .st-up { color: #00D4AA; }

  /* Palette */
  .st-palette { display: flex; flex-wrap: wrap; gap: 2.5%; margin-top: 3%; }
  .st-swatch { display: flex; flex-direction: column; align-items: center; width: 10%; }
  .swatch-block { width: 100%; aspect-ratio: 1; border-radius: 6px; }
  .swatch-name { font-size: clamp(4px, 0.6vw, 7px); color: rgba(255,255,255,0.7); text-align: center; margin-top: 4px; line-height: 1.3; }

  /* Typography */
  .st-type-samples { display: flex; flex-direction: column; gap: 3%; margin-top: 3%; flex: 1; }
  .st-type-row { display: flex; justify-content: space-between; align-items: baseline; padding: 2% 0; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .st-type-demo { flex: 1; }
  .st-type-meta { font-size: clamp(4px, 0.6vw, 7px); color: rgba(255,255,255,0.4); flex-shrink: 0; margin-left: 4%; }

  /* DESIGN.md frame */
  .md-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; background: #fff; padding: 0 2.5rem 2rem; }
  .md-toolbar { display: flex; justify-content: flex-end; padding: 1rem 0; position: sticky; top: 48px; background: #fff; z-index: 10; border-bottom: 1px solid #e5e7f0; }
  .copy-md-btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(0,0,0,0.15); background: #fff; color: var(--near-black); font-size: 13px; font-family: inherit; letter-spacing: -0.12px; cursor: pointer; transition: all 0.2s; }
  .copy-md-btn:hover { background: var(--light-bg); border-color: rgba(0,0,0,0.3); }
  .copy-md-btn.copied { background: #e8f5e9; border-color: #2e7d32; color: #2e7d32; }
  .md-body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif; font-size: 15px; color: #1d1d1f; line-height: 1.6; }
  .md-body h1 { font-size: 28px; font-weight: 600; margin: 2rem 0 1rem; color: #1d1d1f; border-bottom: 1px solid #e5e7f0; padding-bottom: 0.5rem; }
  .md-body h2 { font-size: 22px; font-weight: 600; margin: 2rem 0 0.75rem; color: #1d1d1f; }
  .md-body h3 { font-size: 17px; font-weight: 600; margin: 1.5rem 0 0.5rem; color: #1d1d1f; }
  .md-body p { margin: 0.75rem 0; }
  .md-body ul, .md-body ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .md-body li { margin: 0.25rem 0; }
  .md-body code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; background: #f5f5f7; padding: 2px 6px; border-radius: 4px; }
  .md-body pre { background: #1d1d1f; color: #e0e0e0; padding: 1rem 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
  .md-body pre code { background: none; padding: 0; color: inherit; font-size: 13px; }
  .md-body table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 14px; }
  .md-body th { text-align: left; font-weight: 600; padding: 8px 12px; border-bottom: 2px solid #e5e7f0; }
  .md-body td { padding: 8px 12px; border-bottom: 1px solid #e5e7f0; }
  .md-body hr { border: none; border-top: 1px solid #e5e7f0; margin: 2rem 0; }
  .md-body strong { font-weight: 600; }
  .md-body blockquote { border-left: 3px solid #0071e3; margin: 1rem 0; padding: 0.5rem 1rem; background: #f5f5f7; border-radius: 0 4px 4px 0; }

  footer { background: var(--light-bg); padding: 2rem 0; text-align: center; border-top: 1px solid rgba(0,0,0,0.06); }
  footer p { font-size: 12px; color: var(--text-48); }

  @media (max-width: 834px) {
    .usage-grid { flex-direction: column; }
    .detail-header h1 { font-size: 32px; }
    .st-cols { flex-direction: column; }
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const target = (btn as HTMLElement).dataset.tab;
      document.getElementById('tab-' + target)?.classList.add('active');
    });
  });
  // Copy command button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text);
      btn.innerHTML = '<span style="font-size:12px;color:#2E7D32;">Copied!</span>';
      setTimeout(() => {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>';
      }, 1500);
    });
  });
  // Copy DESIGN.md
  document.getElementById('copy-md')?.addEventListener('click', () => {
    const raw = (document.getElementById('md-raw') as HTMLTextAreaElement)?.value || '';
    navigator.clipboard.writeText(raw);
    const btn = document.getElementById('copy-md')!;
    btn.classList.add('copied');
    btn.querySelector('span')!.textContent = 'Copied!';
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.querySelector('span')!.textContent = 'Copy DESIGN.md';
    }, 2000);
  });
</script>

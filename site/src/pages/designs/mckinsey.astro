---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
const mdPath = path.resolve('..', 'designs', 'mckinsey', 'DESIGN.md');
const mdRaw = fs.readFileSync(mdPath, 'utf-8');
const mdHtml = await marked(mdRaw);
---

<Layout title="McKinsey — slide-design-md">
  <nav>
    <div class="nav-inner">
      <a href="/slide-design-md/" class="nav-back">&larr; Back to designs</a>
      <a href="https://github.com/takumaoshiro/slide-design-md" class="nav-gh" target="_blank">GitHub</a>
    </div>
  </nav>

  <!-- Header -->
  <section class="detail-header">
    <div class="container">
      <h1>McKinsey</h1>
      <p class="detail-tagline">Classic consulting. Navy-anchored, structured, insight-driven executive presentations.</p>
    </div>
  </section>

  <!-- Usage -->
  <section class="usage">
    <div class="container">
      <div class="usage-grid">
        <div class="usage-cmd">
          <div class="cmd-box">
            <code>curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/mckinsey/DESIGN.md</code>
            <button class="copy-btn" data-copy="curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/mckinsey/DESIGN.md" title="Copy">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
          <p class="cmd-help">Run from your project root, then ask your AI assistant to use DESIGN.md for slide generation.</p>
        </div>
        <div class="usage-info">
          <span class="info-badge">16:9</span>
          <span class="info-badge">Georgia / Arial</span>
          <span class="info-badge">Consulting</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Preview tabs -->
  <section class="preview-section">
    <div class="container">
      <div class="tabs-bar">
        <h2>Preview</h2>
        <div class="tabs">
          <button class="tab active" data-tab="preview">Slide Preview</button>
          <button class="tab" data-tab="designmd">DESIGN.md</button>
        </div>
      </div>

      <!-- Slide Preview -->
      <div id="tab-preview" class="tab-content active">
        <div class="slides-grid">

          <!-- Cover Slide -->
          <div class="slide-label">01 — Cover</div>
          <div class="slide-frame">
            <div class="s mk-s">
              <div class="mk-cover-body">
                <div class="mk-firm-name">McKinsey & Company</div>
                <div class="mk-cover-title">Digital Transformation Readiness Assessment</div>
                <div class="mk-cover-rule"></div>
                <div class="mk-cover-sub">Board of Directors Review — April 2025</div>
                <div class="mk-cover-note">Confidential and proprietary</div>
              </div>
            </div>
          </div>

          <!-- Content Slide -->
          <div class="slide-label">02 — Content</div>
          <div class="slide-frame">
            <div class="s mk-s">
              <div class="mk-header-band">
                <div class="mk-action-title">Three capability gaps are limiting digital scale-up across the organization</div>
              </div>
              <div class="mk-inner">
                <div class="mk-exhibit">Exhibit 3</div>
                <div class="mk-cols">
                  <div class="mk-card">
                    <div class="mk-card-bar" style="background:#B81D24;"></div>
                    <div class="mk-card-inner">
                      <div class="mk-card-title">Talent Gap</div>
                      <div class="mk-card-text">Only 12% of mid-level managers have digital fluency scores above threshold</div>
                    </div>
                  </div>
                  <div class="mk-card">
                    <div class="mk-card-bar" style="background:#D4860B;"></div>
                    <div class="mk-card-inner">
                      <div class="mk-card-title">Data Infrastructure</div>
                      <div class="mk-card-text">Legacy systems account for 68% of IT spend, limiting new investment capacity</div>
                    </div>
                  </div>
                  <div class="mk-card">
                    <div class="mk-card-bar" style="background:#003A70;"></div>
                    <div class="mk-card-inner">
                      <div class="mk-card-title">Governance Model</div>
                      <div class="mk-card-text">No single owner for cross-functional digital initiatives across BUs</div>
                    </div>
                  </div>
                </div>
                <div class="mk-source">Source: McKinsey Digital Quotient survey, n=2,400 managers, Q1 2025</div>
              </div>
            </div>
          </div>

          <!-- Data Slide -->
          <div class="slide-label">03 — Data / Table</div>
          <div class="slide-frame">
            <div class="s mk-s">
              <div class="mk-header-band">
                <div class="mk-action-title">APAC revenue grew 18% YoY, offsetting flat performance in EMEA</div>
              </div>
              <div class="mk-inner">
                <div class="mk-exhibit">Exhibit 5</div>
                <table class="mk-table">
                  <thead>
                    <tr>
                      <th>Region</th><th>Revenue ($M)</th><th>YoY Growth</th><th>Margin</th><th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr><td>North America</td><td>$1,240</td><td style="color:#1A7A3A;">+8%</td><td>24.2%</td><td style="color:#1A7A3A;">On track</td></tr>
                    <tr class="mk-alt-row"><td>EMEA</td><td>$860</td><td style="color:#D4860B;">+1%</td><td>18.7%</td><td style="color:#D4860B;">At risk</td></tr>
                    <tr><td>APAC</td><td>$520</td><td style="color:#1A7A3A;">+18%</td><td>21.3%</td><td style="color:#1A7A3A;">On track</td></tr>
                    <tr class="mk-alt-row"><td>LatAm</td><td>$180</td><td style="color:#B81D24;">-4%</td><td>12.1%</td><td style="color:#B81D24;">Off track</td></tr>
                  </tbody>
                </table>
                <div class="mk-source">Source: Internal financial data, FY2024 audited results</div>
              </div>
            </div>
          </div>

          <!-- KPI Slide -->
          <div class="slide-label">04 — KPI Dashboard</div>
          <div class="slide-frame">
            <div class="s mk-s">
              <div class="mk-header-band">
                <div class="mk-action-title">Key performance indicators show mixed progress against Year 1 targets</div>
              </div>
              <div class="mk-inner">
                <div class="mk-exhibit">Exhibit 7</div>
                <div class="mk-kpis">
                  <div class="mk-kpi">
                    <div class="mk-kpi-num" style="color:#1A7A3A;">$2.8B</div>
                    <div class="mk-kpi-label">Total Revenue</div>
                    <div class="mk-kpi-delta" style="color:#1A7A3A;">+8% vs target</div>
                  </div>
                  <div class="mk-kpi">
                    <div class="mk-kpi-num" style="color:#003A70;">19.4%</div>
                    <div class="mk-kpi-label">Blended Margin</div>
                    <div class="mk-kpi-delta" style="color:#D4860B;">-1.1pp vs target</div>
                  </div>
                  <div class="mk-kpi">
                    <div class="mk-kpi-num" style="color:#B81D24;">62</div>
                    <div class="mk-kpi-label">NPS Score</div>
                    <div class="mk-kpi-delta" style="color:#B81D24;">-8 vs target</div>
                  </div>
                  <div class="mk-kpi">
                    <div class="mk-kpi-num" style="color:#1A7A3A;">94%</div>
                    <div class="mk-kpi-label">Retention Rate</div>
                    <div class="mk-kpi-delta" style="color:#1A7A3A;">+2pp vs target</div>
                  </div>
                </div>
                <div class="mk-source">Source: Q4 2024 executive dashboard, targets per Board-approved plan</div>
              </div>
            </div>
          </div>

          <!-- Color Palette -->
          <div class="slide-label">05 — Color Palette</div>
          <div class="slide-frame">
            <div class="s mk-s">
              <div class="mk-header-band">
                <div class="mk-action-title">Color Palette</div>
              </div>
              <div class="mk-inner">
                <div class="mk-palette">
                  <div class="mk-swatch"><div class="swatch-block" style="background:#003A70;"></div><div class="swatch-name">Navy<br/>#003A70</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#2D2D2D;"></div><div class="swatch-name">Dark<br/>#2D2D2D</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#4A4A4A;"></div><div class="swatch-name">Body<br/>#4A4A4A</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#8C8C8C;"></div><div class="swatch-name">Muted<br/>#8C8C8C</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#D4D4D4;"></div><div class="swatch-name">Border<br/>#D4D4D4</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#F2F2F2;"></div><div class="swatch-name">Light BG<br/>#F2F2F2</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#B81D24;"></div><div class="swatch-name">Red<br/>#B81D24</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#1A7A3A;"></div><div class="swatch-name">Green<br/>#1A7A3A</div></div>
                  <div class="mk-swatch"><div class="swatch-block" style="background:#D4860B;"></div><div class="swatch-name">Amber<br/>#D4860B</div></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Typography -->
          <div class="slide-label">06 — Typography</div>
          <div class="slide-frame">
            <div class="s mk-s">
              <div class="mk-header-band">
                <div class="mk-action-title">Typography Scale</div>
              </div>
              <div class="mk-inner">
                <div class="mk-type-samples">
                  <div class="mk-type-row">
                    <span class="mk-type-demo" style="font-family:Georgia,serif;font-size:16px;font-weight:700;color:#2D2D2D;">Action Title — 24pt Georgia Bold</span>
                    <span class="mk-type-meta">Bold · White on Navy</span>
                  </div>
                  <div class="mk-type-row">
                    <span class="mk-type-demo" style="font-family:Georgia,serif;font-size:12px;font-weight:700;color:#003A70;">Section Heading — 14pt Georgia Bold</span>
                    <span class="mk-type-meta">Bold · Navy</span>
                  </div>
                  <div class="mk-type-row">
                    <span class="mk-type-demo" style="font-family:Arial,sans-serif;font-size:10px;color:#4A4A4A;">Body text — 11pt Arial Regular. Standard reading size for exhibit content.</span>
                    <span class="mk-type-meta">Regular · #4A4A4A</span>
                  </div>
                  <div class="mk-type-row">
                    <span class="mk-type-demo" style="font-family:Arial,sans-serif;font-size:8px;font-weight:700;color:#8C8C8C;">Exhibit Number — 9pt Arial Bold</span>
                    <span class="mk-type-meta">Bold · #8C8C8C</span>
                  </div>
                  <div class="mk-type-row">
                    <span class="mk-type-demo" style="font-family:Arial,sans-serif;font-size:7px;color:#8C8C8C;">Source / Caption — 8pt Arial Regular</span>
                    <span class="mk-type-meta">Regular · #8C8C8C</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- DESIGN.md tab -->
      <div id="tab-designmd" class="tab-content">
        <div class="md-frame">
          <div class="md-toolbar">
            <button class="copy-md-btn" id="copy-md">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
              <span>Copy DESIGN.md</span>
            </button>
          </div>
          <div class="md-body" set:html={mdHtml} />
        </div>
        <textarea id="md-raw" style="display:none;">{mdRaw}</textarea>
      </div>

    </div>
  </section>

  <footer>
    <div class="container">
      <p>slide-design-md &mdash; Built for AI agents that create presentations.</p>
    </div>
  </footer>
</Layout>

<style>
  nav { position: sticky; top: 0; z-index: 100; background: rgba(0,0,0,0.8); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); height: 48px; }
  .nav-inner { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; height: 100%; display: flex; align-items: center; justify-content: space-between; }
  .nav-back { font-size: 14px; color: #2997ff; letter-spacing: -0.224px; }
  .nav-back:hover { text-decoration: underline; }
  .nav-gh { font-size: 12px; color: #f5f5f7; opacity: 0.8; }
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; }

  .detail-header { background: var(--black); padding: 3rem 0 2.5rem; }
  .detail-header h1 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 40px; font-weight: 600; color: var(--white); line-height: 1.1; letter-spacing: -0.5px; margin-bottom: 0.5rem; }
  .detail-tagline { font-size: 17px; color: rgba(255,255,255,0.55); letter-spacing: -0.374px; }

  .usage { background: var(--black); padding: 0 0 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .usage-grid { display: flex; gap: 2rem; align-items: flex-start; }
  .usage-cmd { flex: 1; }
  .cmd-box { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; gap: 12px; position: relative; }
  .cmd-box code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; color: #e0e0e0; word-break: break-all; flex: 1; }
  .copy-btn { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 4px; transition: color 0.2s; flex-shrink: 0; }
  .copy-btn:hover { color: var(--white); }
  .cmd-help { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 0.5rem; letter-spacing: -0.12px; }
  .usage-info { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 4px; }
  .info-badge { font-size: 12px; color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.15); border-radius: 4px; padding: 4px 10px; letter-spacing: -0.12px; }

  .preview-section { background: var(--light-bg); padding: 3rem 0 4rem; }
  .tabs-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .tabs-bar h2 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 28px; font-weight: 600; color: var(--near-black); }
  .tabs { display: flex; border: 1px solid rgba(0,0,0,0.15); border-radius: 8px; overflow: hidden; }
  .tab { padding: 6px 18px; font-size: 14px; font-family: inherit; letter-spacing: -0.224px; border: none; background: transparent; color: var(--text-80); cursor: pointer; transition: all 0.2s; }
  .tab.active { background: var(--near-black); color: var(--white); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* Slides grid */
  .slides-grid { display: flex; flex-direction: column; gap: 1rem; }
  .slide-label { font-size: 12px; font-weight: 600; color: var(--text-48); letter-spacing: 0.5px; text-transform: uppercase; margin-top: 1rem; }
  .slide-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }

  /* Base slide */
  .s { width: 100%; aspect-ratio: 16/9; position: relative; overflow: hidden; }
  .mk-s { background: #FFFFFF; font-family: Arial, sans-serif; }

  /* Navy header band */
  .mk-header-band { background: #003A70; padding: 3% 5.5% 2.5%; }
  .mk-action-title { font-family: Georgia, serif; font-size: clamp(9px, 1.8vw, 20px); font-weight: 700; color: #FFFFFF; line-height: 1.3; }

  /* Cover */
  .mk-cover-body { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 8%; gap: 3%; }
  .mk-firm-name { font-family: Georgia, serif; font-size: clamp(7px, 1vw, 12px); font-weight: 700; color: #003A70; letter-spacing: 2px; text-transform: uppercase; }
  .mk-cover-title { font-family: Georgia, serif; font-size: clamp(14px, 3vw, 36px); font-weight: 700; color: #2D2D2D; text-align: center; line-height: 1.2; }
  .mk-cover-rule { width: 15%; height: 2px; background: #003A70; }
  .mk-cover-sub { font-size: clamp(7px, 1.1vw, 14px); color: #8C8C8C; text-align: center; }
  .mk-cover-note { font-size: clamp(5px, 0.7vw, 9px); color: #8C8C8C; font-style: italic; }

  /* Inner layout */
  .mk-inner { padding: 2% 5.5% 3%; height: calc(100% - 10%); display: flex; flex-direction: column; }
  .mk-exhibit { font-size: clamp(5px, 0.75vw, 9px); font-weight: 700; color: #8C8C8C; margin-bottom: 2%; }
  .mk-source { margin-top: auto; font-size: clamp(4px, 0.6vw, 8px); color: #8C8C8C; }

  /* Cards */
  .mk-cols { display: flex; gap: 2.5%; flex: 1; }
  .mk-card { flex: 1; background: #F2F2F2; display: flex; overflow: hidden; }
  .mk-card-bar { width: 4px; flex-shrink: 0; }
  .mk-card-inner { padding: 4% 5%; }
  .mk-card-title { font-family: Georgia, serif; font-size: clamp(6px, 1vw, 12px); font-weight: 700; color: #2D2D2D; margin-bottom: 3%; }
  .mk-card-text { font-size: clamp(5px, 0.8vw, 9px); color: #4A4A4A; line-height: 1.5; }

  /* Table */
  .mk-table { width: 100%; border-collapse: collapse; flex: 1; }
  .mk-table th { background: #003A70; color: #FFFFFF; font-size: clamp(5px, 0.8vw, 9px); font-weight: 700; padding: 1.8% 2%; text-align: left; }
  .mk-table td { font-size: clamp(5px, 0.8vw, 9px); color: #4A4A4A; padding: 1.8% 2%; border-bottom: 1px solid #D4D4D4; }
  .mk-alt-row { background: #F2F2F2; }

  /* KPI */
  .mk-kpis { display: flex; gap: 2.5%; flex: 1; }
  .mk-kpi { flex: 1; background: #F2F2F2; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3%; }
  .mk-kpi-num { font-size: clamp(12px, 2.5vw, 28px); font-weight: 700; }
  .mk-kpi-label { font-size: clamp(5px, 0.8vw, 9px); color: #4A4A4A; margin-top: 2%; }
  .mk-kpi-delta { font-size: clamp(5px, 0.7vw, 8px); font-weight: 700; margin-top: 1%; }

  /* Palette */
  .mk-palette { display: flex; flex-wrap: wrap; gap: 2%; margin-top: 3%; }
  .mk-swatch { display: flex; flex-direction: column; align-items: center; width: 9%; }
  .swatch-block { width: 100%; aspect-ratio: 1; border-radius: 2px; border: 1px solid #D4D4D4; }
  .swatch-name { font-size: clamp(4px, 0.6vw, 7px); color: #4A4A4A; text-align: center; margin-top: 4px; line-height: 1.3; }

  /* Typography */
  .mk-type-samples { display: flex; flex-direction: column; gap: 3%; margin-top: 2%; flex: 1; }
  .mk-type-row { display: flex; justify-content: space-between; align-items: baseline; padding: 1.5% 0; border-bottom: 1px solid #F2F2F2; }
  .mk-type-demo { flex: 1; }
  .mk-type-meta { font-size: clamp(4px, 0.6vw, 7px); color: #8C8C8C; flex-shrink: 0; margin-left: 4%; }

  /* DESIGN.md frame */
  .md-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; background: #fff; padding: 0 2.5rem 2rem; }
  .md-toolbar { display: flex; justify-content: flex-end; padding: 1rem 0; position: sticky; top: 48px; background: #fff; z-index: 10; border-bottom: 1px solid #e5e7f0; }
  .copy-md-btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(0,0,0,0.15); background: #fff; color: var(--near-black); font-size: 13px; font-family: inherit; letter-spacing: -0.12px; cursor: pointer; transition: all 0.2s; }
  .copy-md-btn:hover { background: var(--light-bg); border-color: rgba(0,0,0,0.3); }
  .copy-md-btn.copied { background: #e8f5e9; border-color: #2e7d32; color: #2e7d32; }
  .md-body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif; font-size: 15px; color: #1d1d1f; line-height: 1.6; }
  .md-body h1 { font-size: 28px; font-weight: 600; margin: 2rem 0 1rem; color: #1d1d1f; border-bottom: 1px solid #e5e7f0; padding-bottom: 0.5rem; }
  .md-body h2 { font-size: 22px; font-weight: 600; margin: 2rem 0 0.75rem; color: #1d1d1f; }
  .md-body h3 { font-size: 17px; font-weight: 600; margin: 1.5rem 0 0.5rem; color: #1d1d1f; }
  .md-body p { margin: 0.75rem 0; }
  .md-body ul, .md-body ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .md-body li { margin: 0.25rem 0; }
  .md-body code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; background: #f5f5f7; padding: 2px 6px; border-radius: 4px; }
  .md-body pre { background: #1d1d1f; color: #e0e0e0; padding: 1rem 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
  .md-body pre code { background: none; padding: 0; color: inherit; font-size: 13px; }
  .md-body table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 14px; }
  .md-body th { text-align: left; font-weight: 600; padding: 8px 12px; border-bottom: 2px solid #e5e7f0; }
  .md-body td { padding: 8px 12px; border-bottom: 1px solid #e5e7f0; }
  .md-body hr { border: none; border-top: 1px solid #e5e7f0; margin: 2rem 0; }
  .md-body strong { font-weight: 600; }
  .md-body blockquote { border-left: 3px solid #0071e3; margin: 1rem 0; padding: 0.5rem 1rem; background: #f5f5f7; border-radius: 0 4px 4px 0; }

  footer { background: var(--light-bg); padding: 2rem 0; text-align: center; border-top: 1px solid rgba(0,0,0,0.06); }
  footer p { font-size: 12px; color: var(--text-48); }

  @media (max-width: 834px) {
    .usage-grid { flex-direction: column; }
    .detail-header h1 { font-size: 32px; }
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const target = (btn as HTMLElement).dataset.tab;
      document.getElementById('tab-' + target)?.classList.add('active');
    });
  });
  // Copy command button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text);
      btn.innerHTML = '<span style="font-size:12px;color:#2E7D32;">Copied!</span>';
      setTimeout(() => {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>';
      }, 1500);
    });
  });
  // Copy DESIGN.md
  document.getElementById('copy-md')?.addEventListener('click', () => {
    const raw = (document.getElementById('md-raw') as HTMLTextAreaElement)?.value || '';
    navigator.clipboard.writeText(raw);
    const btn = document.getElementById('copy-md')!;
    btn.classList.add('copied');
    btn.querySelector('span')!.textContent = 'Copied!';
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.querySelector('span')!.textContent = 'Copy DESIGN.md';
    }, 2000);
  });
</script>

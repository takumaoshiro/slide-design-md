---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
const mdPath = path.resolve('..', 'designs', 'softbank', 'DESIGN.md');
const mdRaw = fs.readFileSync(mdPath, 'utf-8');
const mdHtml = await marked(mdRaw);
---

<Layout title="SoftBank — slide-design-md">
  <nav>
    <div class="nav-inner">
      <a href="/slide-design-md/" class="nav-back">&larr; Back to designs</a>
      <a href="https://github.com/takumaoshiro/slide-design-md" class="nav-gh" target="_blank">GitHub</a>
    </div>
  </nav>

  <!-- Header -->
  <section class="detail-header">
    <div class="container">
      <h1>SoftBank</h1>
      <p class="detail-tagline">Japanese corporate. Silver/gray gradient, authoritative, vision-driven. Investor-ready.</p>
    </div>
  </section>

  <!-- Usage -->
  <section class="usage">
    <div class="container">
      <div class="usage-grid">
        <div class="usage-cmd">
          <div class="cmd-box">
            <code>curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/softbank/DESIGN.md</code>
            <button class="copy-btn" data-copy="curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/softbank/DESIGN.md" title="Copy">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
          <p class="cmd-help">Run from your project root, then ask your AI assistant to use DESIGN.md for slide generation.</p>
        </div>
        <div class="usage-info">
          <span class="info-badge">16:9</span>
          <span class="info-badge">Noto Sans JP / Arial</span>
          <span class="info-badge">Corporate</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Preview tabs -->
  <section class="preview-section">
    <div class="container">
      <div class="tabs-bar">
        <h2>Preview</h2>
        <div class="tabs">
          <button class="tab active" data-tab="preview">Slide Preview</button>
          <button class="tab" data-tab="designmd">DESIGN.md</button>
        </div>
      </div>

      <!-- Slide Preview -->
      <div id="tab-preview" class="tab-content active">
        <div class="slides-grid">

          <!-- Cover Slide -->
          <div class="slide-label">01 — Cover</div>
          <div class="slide-frame">
            <div class="s sb-s sb-cover">
              <div class="sb-cover-gradient"></div>
              <div class="sb-cover-body">
                <div class="sb-cover-logo">SoftBank</div>
                <div class="sb-cover-title">Vision for the Next Decade</div>
                <div class="sb-cover-sep"></div>
                <div class="sb-cover-sub">SoftBank Group Corp. — Investor Presentation 2025</div>
              </div>
            </div>
          </div>

          <!-- Content Slide -->
          <div class="slide-label">02 — Content</div>
          <div class="slide-frame">
            <div class="s sb-s">
              <div class="sb-header">
                <div class="sb-header-title">Growth Strategy</div>
                <div class="sb-header-sub">Next-generation platform investments</div>
              </div>
              <div class="sb-inner">
                <div class="sb-vision">"AI will be the defining technology of the 21st century."</div>
                <div class="sb-cols">
                  <div class="sb-card">
                    <div class="sb-card-bar" style="background:#0078D4;"></div>
                    <div class="sb-card-inner">
                      <div class="sb-card-title">AI & Robotics</div>
                      <div class="sb-card-text">Strategic investments in foundation models, autonomous systems, and intelligent infrastructure.</div>
                    </div>
                  </div>
                  <div class="sb-card">
                    <div class="sb-card-bar" style="background:#1B2A4A;"></div>
                    <div class="sb-card-inner">
                      <div class="sb-card-title">Global Connectivity</div>
                      <div class="sb-card-text">Expanding network reach through 5G, satellite, and next-gen telecom platforms worldwide.</div>
                    </div>
                  </div>
                </div>
                <div class="sb-footer-text">SoftBank Group Corp.</div>
              </div>
            </div>
          </div>

          <!-- Data Slide -->
          <div class="slide-label">03 — Data / Table</div>
          <div class="slide-frame">
            <div class="s sb-s">
              <div class="sb-header">
                <div class="sb-header-title">Financial Summary</div>
                <div class="sb-header-sub">FY2024 Consolidated Results (JPY Billions)</div>
              </div>
              <div class="sb-inner">
                <table class="sb-table">
                  <thead>
                    <tr>
                      <th>Segment</th><th>Revenue</th><th>Operating Income</th><th>YoY</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr><td>Investment</td><td>4,120</td><td>1,830</td><td style="color:#008A00;">+24%</td></tr>
                    <tr class="sb-row-alt"><td>Telecom</td><td>3,890</td><td>920</td><td style="color:#008A00;">+6%</td></tr>
                    <tr><td>ARM</td><td>1,240</td><td>410</td><td style="color:#008A00;">+18%</td></tr>
                    <tr class="sb-row-alt"><td>Other</td><td>680</td><td>-120</td><td style="color:#CC0000;">-8%</td></tr>
                  </tbody>
                </table>
                <div class="sb-footer-text">SoftBank Group Corp.</div>
              </div>
            </div>
          </div>

          <!-- KPI Slide -->
          <div class="slide-label">04 — KPI Dashboard</div>
          <div class="slide-frame">
            <div class="s sb-s">
              <div class="sb-header">
                <div class="sb-header-title">Key Performance Indicators</div>
                <div class="sb-header-sub">FY2024 Q4 Highlights</div>
              </div>
              <div class="sb-inner">
                <div class="sb-kpis">
                  <div class="sb-kpi">
                    <div class="sb-kpi-num" style="color:#1B2A4A;">9.93T</div>
                    <div class="sb-kpi-label">Revenue (JPY)</div>
                  </div>
                  <div class="sb-kpi">
                    <div class="sb-kpi-num" style="color:#008A00;">+24%</div>
                    <div class="sb-kpi-label">YoY Growth</div>
                  </div>
                  <div class="sb-kpi">
                    <div class="sb-kpi-num" style="color:#0078D4;">475</div>
                    <div class="sb-kpi-label">Portfolio Companies</div>
                  </div>
                  <div class="sb-kpi">
                    <div class="sb-kpi-num" style="color:#1B2A4A;">$180B</div>
                    <div class="sb-kpi-label">AUM (Vision Fund)</div>
                  </div>
                </div>
                <div class="sb-footer-text">SoftBank Group Corp.</div>
              </div>
            </div>
          </div>

          <!-- Color Palette -->
          <div class="slide-label">05 — Color Palette</div>
          <div class="slide-frame">
            <div class="s sb-s">
              <div class="sb-header">
                <div class="sb-header-title">Color Palette</div>
              </div>
              <div class="sb-inner">
                <div class="sb-palette">
                  <div class="sb-swatch"><div class="swatch-block" style="background:#1B2A4A;"></div><div class="swatch-name">Navy<br/>#1B2A4A</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#8C8C8C;"></div><div class="swatch-name">Silver<br/>#8C8C8C</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#FFFFFF; border:1px solid #D0D0D0;"></div><div class="swatch-name">White<br/>#FFFFFF</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#F5F5F5;"></div><div class="swatch-name">Light BG<br/>#F5F5F5</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#333333;"></div><div class="swatch-name">Body<br/>#333333</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#999999;"></div><div class="swatch-name">Muted<br/>#999999</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#0078D4;"></div><div class="swatch-name">Accent<br/>#0078D4</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#008A00;"></div><div class="swatch-name">Green<br/>#008A00</div></div>
                  <div class="sb-swatch"><div class="swatch-block" style="background:#CC0000;"></div><div class="swatch-name">Red<br/>#CC0000</div></div>
                </div>
                <div class="sb-footer-text">SoftBank Group Corp.</div>
              </div>
            </div>
          </div>

          <!-- Typography -->
          <div class="slide-label">06 — Typography</div>
          <div class="slide-frame">
            <div class="s sb-s">
              <div class="sb-header">
                <div class="sb-header-title">Typography Scale</div>
              </div>
              <div class="sb-inner">
                <div class="sb-type-samples">
                  <div class="sb-type-row">
                    <span class="sb-type-demo" style="font-family:'Noto Sans JP',Arial,sans-serif;font-size:18px;font-weight:700;color:#1B2A4A;">Vision Statement — 36pt Bold</span>
                    <span class="sb-type-meta">Bold / Navy</span>
                  </div>
                  <div class="sb-type-row">
                    <span class="sb-type-demo" style="font-family:'Noto Sans JP',Arial,sans-serif;font-size:14px;font-weight:700;color:#1B2A4A;">Slide Title — 28pt Noto Sans JP</span>
                    <span class="sb-type-meta">Bold / #1B2A4A</span>
                  </div>
                  <div class="sb-type-row">
                    <span class="sb-type-demo" style="font-family:'Noto Sans JP',Arial,sans-serif;font-size:10px;font-weight:700;color:#0078D4;">Section Heading — 16pt Bold</span>
                    <span class="sb-type-meta">Bold / Accent</span>
                  </div>
                  <div class="sb-type-row">
                    <span class="sb-type-demo" style="font-family:'Noto Sans JP',Arial,sans-serif;font-size:9px;color:#333333;">Body text — 12pt Noto Sans JP Regular. Standard reading size for content slides.</span>
                    <span class="sb-type-meta">Regular / #333333</span>
                  </div>
                  <div class="sb-type-row">
                    <span class="sb-type-demo" style="font-family:'Noto Sans JP',Arial,sans-serif;font-size:7px;color:#999999;">Caption / Note — 9pt Regular</span>
                    <span class="sb-type-meta">Regular / #999999</span>
                  </div>
                </div>
                <div class="sb-footer-text">SoftBank Group Corp.</div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- DESIGN.md tab -->
      <div id="tab-designmd" class="tab-content">
        <div class="md-frame">
          <div class="md-toolbar">
            <button class="copy-md-btn" id="copy-md">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
              <span>Copy DESIGN.md</span>
            </button>
          </div>
          <div class="md-body" set:html={mdHtml} />
        </div>
        <textarea id="md-raw" style="display:none;">{mdRaw}</textarea>
      </div>

    </div>
  </section>

  <footer>
    <div class="container">
      <p>slide-design-md &mdash; Built for AI agents that create presentations.</p>
    </div>
  </footer>
</Layout>

<style>
  nav { position: sticky; top: 0; z-index: 100; background: rgba(0,0,0,0.8); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); height: 48px; }
  .nav-inner { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; height: 100%; display: flex; align-items: center; justify-content: space-between; }
  .nav-back { font-size: 14px; color: #2997ff; letter-spacing: -0.224px; }
  .nav-back:hover { text-decoration: underline; }
  .nav-gh { font-size: 12px; color: #f5f5f7; opacity: 0.8; }
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; }

  .detail-header { background: var(--black); padding: 3rem 0 2.5rem; }
  .detail-header h1 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 40px; font-weight: 600; color: var(--white); line-height: 1.1; letter-spacing: -0.5px; margin-bottom: 0.5rem; }
  .detail-tagline { font-size: 17px; color: rgba(255,255,255,0.55); letter-spacing: -0.374px; }

  .usage { background: var(--black); padding: 0 0 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .usage-grid { display: flex; gap: 2rem; align-items: flex-start; }
  .usage-cmd { flex: 1; }
  .cmd-box { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; gap: 12px; position: relative; }
  .cmd-box code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; color: #e0e0e0; word-break: break-all; flex: 1; }
  .copy-btn { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 4px; transition: color 0.2s; flex-shrink: 0; }
  .copy-btn:hover { color: var(--white); }
  .cmd-help { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 0.5rem; letter-spacing: -0.12px; }
  .usage-info { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 4px; }
  .info-badge { font-size: 12px; color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.15); border-radius: 4px; padding: 4px 10px; letter-spacing: -0.12px; }

  .preview-section { background: var(--light-bg); padding: 3rem 0 4rem; }
  .tabs-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .tabs-bar h2 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 28px; font-weight: 600; color: var(--near-black); }
  .tabs { display: flex; border: 1px solid rgba(0,0,0,0.15); border-radius: 8px; overflow: hidden; }
  .tab { padding: 6px 18px; font-size: 14px; font-family: inherit; letter-spacing: -0.224px; border: none; background: transparent; color: var(--text-80); cursor: pointer; transition: all 0.2s; }
  .tab.active { background: var(--near-black); color: var(--white); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* Slides grid */
  .slides-grid { display: flex; flex-direction: column; gap: 1rem; }
  .slide-label { font-size: 12px; font-weight: 600; color: var(--text-48); letter-spacing: 0.5px; text-transform: uppercase; margin-top: 1rem; }
  .slide-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }

  /* Base slide */
  .s { width: 100%; aspect-ratio: 16/9; position: relative; overflow: hidden; }
  .sb-s { background: #FFFFFF; font-family: 'Noto Sans JP', Arial, sans-serif; }

  /* Cover */
  .sb-cover { background: #1B2A4A; }
  .sb-cover-gradient { position: absolute; bottom: 0; left: 0; right: 0; height: 40%; background: linear-gradient(to top, rgba(140,140,140,0.15), transparent); }
  .sb-cover-body { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 8%; gap: 3%; z-index: 1; }
  .sb-cover-logo { font-size: clamp(8px, 1vw, 12px); font-weight: 700; color: #8C8C8C; letter-spacing: 3px; text-transform: uppercase; }
  .sb-cover-title { font-size: clamp(16px, 3.5vw, 40px); font-weight: 700; color: #FFFFFF; text-align: center; line-height: 1.2; }
  .sb-cover-sep { width: 10%; height: 2px; background: linear-gradient(to right, #8C8C8C, #FFFFFF); }
  .sb-cover-sub { font-size: clamp(6px, 1vw, 12px); color: #8C8C8C; text-align: center; }

  /* Navy Header Bar */
  .sb-header { background: #1B2A4A; padding: 3% 6% 2.5%; }
  .sb-header-title { font-size: clamp(10px, 2.2vw, 28px); font-weight: 700; color: #FFFFFF; }
  .sb-header-sub { font-size: clamp(6px, 0.9vw, 14px); color: #8C8C8C; margin-top: 1%; }

  /* Inner layout */
  .sb-inner { padding: 4% 6% 3%; flex: 1; display: flex; flex-direction: column; }
  .sb-footer-text { margin-top: auto; text-align: right; font-size: clamp(5px, 0.7vw, 8px); color: #8C8C8C; }

  /* Vision statement */
  .sb-vision { font-size: clamp(9px, 1.8vw, 22px); font-weight: 700; color: #1B2A4A; font-style: italic; text-align: center; padding: 2% 4%; margin-bottom: 3%; }

  /* Cards */
  .sb-cols { display: flex; gap: 3%; flex: 1; }
  .sb-card { flex: 1; background: #FFFFFF; border: 1px solid #D0D0D0; border-radius: 4px; display: flex; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .sb-card-bar { width: 4px; flex-shrink: 0; }
  .sb-card-inner { padding: 3% 4%; }
  .sb-card-title { font-size: clamp(6px, 1.1vw, 12px); font-weight: 700; color: #1B2A4A; margin-bottom: 2%; }
  .sb-card-text { font-size: clamp(5px, 0.8vw, 10px); color: #333333; line-height: 1.5; }

  /* Table */
  .sb-table { width: 100%; border-collapse: collapse; flex: 1; }
  .sb-table th { background: #1B2A4A; color: #FFFFFF; font-size: clamp(5px, 0.85vw, 10px); font-weight: 700; padding: 1.8% 2.5%; text-align: left; }
  .sb-table td { font-size: clamp(5px, 0.85vw, 10px); color: #333333; padding: 1.8% 2.5%; border-bottom: 1px solid #D0D0D0; }
  .sb-row-alt { background: #F5F5F5; }

  /* KPI */
  .sb-kpis { display: flex; gap: 3%; margin-top: 2%; flex: 1; }
  .sb-kpi { flex: 1; background: #FFFFFF; border: 1px solid #D0D0D0; border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3%; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .sb-kpi-num { font-size: clamp(12px, 2.5vw, 32px); font-weight: 700; }
  .sb-kpi-label { font-size: clamp(5px, 0.75vw, 10px); color: #8C8C8C; margin-top: 3%; }

  /* Palette */
  .sb-palette { display: flex; flex-wrap: wrap; gap: 2%; margin-top: 2%; }
  .sb-swatch { display: flex; flex-direction: column; align-items: center; width: 9%; }
  .swatch-block { width: 100%; aspect-ratio: 1; border-radius: 4px; border: 1px solid #D0D0D0; }
  .swatch-name { font-size: clamp(4px, 0.6vw, 7px); color: #333333; text-align: center; margin-top: 4px; line-height: 1.3; }

  /* Typography */
  .sb-type-samples { display: flex; flex-direction: column; gap: 3%; margin-top: 2%; flex: 1; }
  .sb-type-row { display: flex; justify-content: space-between; align-items: baseline; padding: 1.5% 0; border-bottom: 1px solid #F5F5F5; }
  .sb-type-demo { flex: 1; }
  .sb-type-meta { font-size: clamp(4px, 0.6vw, 7px); color: #8C8C8C; flex-shrink: 0; margin-left: 4%; }

  /* DESIGN.md frame */
  .md-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; background: #fff; padding: 0 2.5rem 2rem; }
  .md-toolbar { display: flex; justify-content: flex-end; padding: 1rem 0; position: sticky; top: 48px; background: #fff; z-index: 10; border-bottom: 1px solid #e5e7f0; }
  .copy-md-btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(0,0,0,0.15); background: #fff; color: var(--near-black); font-size: 13px; font-family: inherit; letter-spacing: -0.12px; cursor: pointer; transition: all 0.2s; }
  .copy-md-btn:hover { background: var(--light-bg); border-color: rgba(0,0,0,0.3); }
  .copy-md-btn.copied { background: #e8f5e9; border-color: #2e7d32; color: #2e7d32; }
  .md-body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif; font-size: 15px; color: #1d1d1f; line-height: 1.6; }
  .md-body h1 { font-size: 28px; font-weight: 600; margin: 2rem 0 1rem; color: #1d1d1f; border-bottom: 1px solid #e5e7f0; padding-bottom: 0.5rem; }
  .md-body h2 { font-size: 22px; font-weight: 600; margin: 2rem 0 0.75rem; color: #1d1d1f; }
  .md-body h3 { font-size: 17px; font-weight: 600; margin: 1.5rem 0 0.5rem; color: #1d1d1f; }
  .md-body p { margin: 0.75rem 0; }
  .md-body ul, .md-body ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .md-body li { margin: 0.25rem 0; }
  .md-body code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; background: #f5f5f7; padding: 2px 6px; border-radius: 4px; }
  .md-body pre { background: #1d1d1f; color: #e0e0e0; padding: 1rem 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
  .md-body pre code { background: none; padding: 0; color: inherit; font-size: 13px; }
  .md-body table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 14px; }
  .md-body th { text-align: left; font-weight: 600; padding: 8px 12px; border-bottom: 2px solid #e5e7f0; }
  .md-body td { padding: 8px 12px; border-bottom: 1px solid #e5e7f0; }
  .md-body hr { border: none; border-top: 1px solid #e5e7f0; margin: 2rem 0; }
  .md-body strong { font-weight: 600; }
  .md-body blockquote { border-left: 3px solid #0071e3; margin: 1rem 0; padding: 0.5rem 1rem; background: #f5f5f7; border-radius: 0 4px 4px 0; }

  footer { background: var(--light-bg); padding: 2rem 0; text-align: center; border-top: 1px solid rgba(0,0,0,0.06); }
  footer p { font-size: 12px; color: var(--text-48); }

  @media (max-width: 834px) {
    .usage-grid { flex-direction: column; }
    .detail-header h1 { font-size: 32px; }
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const target = (btn as HTMLElement).dataset.tab;
      document.getElementById('tab-' + target)?.classList.add('active');
    });
  });
  // Copy command button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text);
      btn.innerHTML = '<span style="font-size:12px;color:#2E7D32;">Copied!</span>';
      setTimeout(() => {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>';
      }, 1500);
    });
  });
  // Copy DESIGN.md
  document.getElementById('copy-md')?.addEventListener('click', () => {
    const raw = (document.getElementById('md-raw') as HTMLTextAreaElement)?.value || '';
    navigator.clipboard.writeText(raw);
    const btn = document.getElementById('copy-md')!;
    btn.classList.add('copied');
    btn.querySelector('span')!.textContent = 'Copied!';
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.querySelector('span')!.textContent = 'Copy DESIGN.md';
    }, 2000);
  });
</script>

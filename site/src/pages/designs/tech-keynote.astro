---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
const mdPath = path.resolve('..', 'designs', 'tech-keynote', 'DESIGN.md');
const mdRaw = fs.readFileSync(mdPath, 'utf-8');
const mdHtml = await marked(mdRaw);
---

<Layout title="Tech Keynote — slide-design-md">
  <nav>
    <div class="nav-inner">
      <a href="/slide-design-md/" class="nav-back">&larr; Back to designs</a>
      <a href="https://github.com/takumaoshiro/slide-design-md" class="nav-gh" target="_blank">GitHub</a>
    </div>
  </nav>

  <!-- Header -->
  <section class="detail-header">
    <div class="container">
      <h1>Tech Keynote</h1>
      <p class="detail-tagline">Dark stage aesthetic. One idea per slide, massive typography, 40%+ dark space. No bullet points.</p>
    </div>
  </section>

  <!-- Usage -->
  <section class="usage">
    <div class="container">
      <div class="usage-grid">
        <div class="usage-cmd">
          <div class="cmd-box">
            <code>curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/tech-keynote/DESIGN.md</code>
            <button class="copy-btn" data-copy="curl -o DESIGN.md https://raw.githubusercontent.com/takumaoshiro/slide-design-md/main/designs/tech-keynote/DESIGN.md" title="Copy">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
          <p class="cmd-help">Run from your project root, then ask your AI assistant to use DESIGN.md for slide generation.</p>
        </div>
        <div class="usage-info">
          <span class="info-badge">16:9</span>
          <span class="info-badge">SF Pro Display / SF Mono</span>
          <span class="info-badge">Dark Stage</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Preview tabs -->
  <section class="preview-section">
    <div class="container">
      <div class="tabs-bar">
        <h2>Preview</h2>
        <div class="tabs">
          <button class="tab active" data-tab="preview">Slide Preview</button>
          <button class="tab" data-tab="designmd">DESIGN.md</button>
        </div>
      </div>

      <!-- Slide Preview -->
      <div id="tab-preview" class="tab-content active">
        <div class="slides-grid">

          <!-- Cover Slide -->
          <div class="slide-label">01 — Cover</div>
          <div class="slide-frame">
            <div class="s tk-s">
              <div class="tk-cover">
                <div class="tk-cover-intro">Introducing</div>
                <div class="tk-cover-hero">Product X</div>
                <div class="tk-cover-sub">The next generation of performance.</div>
                <div class="tk-cover-ctas">
                  <span class="tk-pill tk-pill-outline">Learn more</span>
                  <span class="tk-pill tk-pill-filled">Get started</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Statement Slide -->
          <div class="slide-label">02 — Statement</div>
          <div class="slide-frame">
            <div class="s tk-s">
              <div class="tk-statement">
                <div class="tk-statement-text">10x faster than<br/>anything before.</div>
                <div class="tk-statement-sub">Benchmarked against every major competitor in production workloads.</div>
              </div>
            </div>
          </div>

          <!-- Big Number Slide -->
          <div class="slide-label">03 — Big Number</div>
          <div class="slide-frame">
            <div class="s tk-s">
              <div class="tk-bignum">
                <div class="tk-bignum-value">97%</div>
                <div class="tk-bignum-label">Customer satisfaction</div>
                <div class="tk-bignum-delta">+12% YoY</div>
              </div>
            </div>
          </div>

          <!-- Code Slide -->
          <div class="slide-label">04 — Code</div>
          <div class="slide-frame">
            <div class="s tk-s">
              <div class="tk-code-slide">
                <div class="tk-code-title">API Integration</div>
                <div class="tk-code-card">
                  <pre class="tk-code-block"><span class="tk-kw">const</span> <span class="tk-var">response</span> <span class="tk-op">=</span> <span class="tk-kw">await</span> <span class="tk-fn">fetch</span>(<span class="tk-str">'/api/v2/data'</span>, &#123;
  <span class="tk-key">method</span>: <span class="tk-str">'POST'</span>,
  <span class="tk-key">headers</span>: &#123; <span class="tk-str">'Content-Type'</span>: <span class="tk-str">'application/json'</span> &#125;,
  <span class="tk-key">body</span>: <span class="tk-fn">JSON.stringify</span>(&#123; <span class="tk-key">query</span>: <span class="tk-var">input</span> &#125;)
&#125;);

<span class="tk-kw">const</span> &#123; <span class="tk-var">results</span> &#125; <span class="tk-op">=</span> <span class="tk-kw">await</span> <span class="tk-var">response</span>.<span class="tk-fn">json</span>();</pre>
                </div>
              </div>
            </div>
          </div>

          <!-- Color Palette -->
          <div class="slide-label">05 — Color Palette</div>
          <div class="slide-frame">
            <div class="s tk-s">
              <div class="tk-inner">
                <div class="tk-section-title">Color Palette</div>
                <div class="tk-palette">
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#0A0A0A;"></div><div class="tk-swatch-name">Background<br/>#0A0A0A</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#141414;"></div><div class="tk-swatch-name">Card<br/>#141414</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#FFFFFF;"></div><div class="tk-swatch-name">Headline<br/>#FFFFFF</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#E0E0E0;"></div><div class="tk-swatch-name">Body<br/>#E0E0E0</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#888888;"></div><div class="tk-swatch-name">Muted<br/>#888888</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#0A84FF;"></div><div class="tk-swatch-name">Blue<br/>#0A84FF</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#BF5AF2;"></div><div class="tk-swatch-name">Purple<br/>#BF5AF2</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#30D158;"></div><div class="tk-swatch-name">Green<br/>#30D158</div></div>
                  <div class="tk-swatch"><div class="tk-swatch-block" style="background:#FF453A;"></div><div class="tk-swatch-name">Red<br/>#FF453A</div></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Typography -->
          <div class="slide-label">06 — Typography</div>
          <div class="slide-frame">
            <div class="s tk-s">
              <div class="tk-inner">
                <div class="tk-section-title">Typography Scale</div>
                <div class="tk-type-samples">
                  <div class="tk-type-row">
                    <span class="tk-type-demo" style="font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif;font-size:clamp(18px,4vw,36px);font-weight:700;color:#FFFFFF;">Hero Headline — 72pt</span>
                    <span class="tk-type-meta">Bold · #FFFFFF</span>
                  </div>
                  <div class="tk-type-row">
                    <span class="tk-type-demo" style="font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif;font-size:clamp(12px,2.6vw,22px);font-weight:600;color:#FFFFFF;">Slide Title — 44pt</span>
                    <span class="tk-type-meta">Semibold · #FFFFFF</span>
                  </div>
                  <div class="tk-type-row">
                    <span class="tk-type-demo" style="font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif;font-size:clamp(8px,1.5vw,14px);font-weight:400;color:#E0E0E0;">Subtitle text for supporting context — 24pt</span>
                    <span class="tk-type-meta">Regular · #E0E0E0</span>
                  </div>
                  <div class="tk-type-row">
                    <span class="tk-type-demo" style="font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif;font-size:clamp(7px,1.2vw,12px);font-weight:400;color:#E0E0E0;">Body text for descriptions and details — 20pt</span>
                    <span class="tk-type-meta">Regular · #E0E0E0</span>
                  </div>
                  <div class="tk-type-row">
                    <span class="tk-type-demo" style="font-family:'SF Mono',Consolas,monospace;font-size:clamp(6px,1.1vw,11px);font-weight:400;color:#E0E0E0;">const code = "monospace"; // 18pt SF Mono</span>
                    <span class="tk-type-meta">Mono · #E0E0E0</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- DESIGN.md tab -->
      <div id="tab-designmd" class="tab-content">
        <div class="md-frame">
          <div class="md-body" set:html={mdHtml} />
        </div>
      </div>

    </div>
  </section>

  <footer>
    <div class="container">
      <p>slide-design-md &mdash; Built for AI agents that create presentations.</p>
    </div>
  </footer>
</Layout>

<style>
  nav { position: sticky; top: 0; z-index: 100; background: rgba(0,0,0,0.8); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); height: 48px; }
  .nav-inner { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; height: 100%; display: flex; align-items: center; justify-content: space-between; }
  .nav-back { font-size: 14px; color: #2997ff; letter-spacing: -0.224px; }
  .nav-back:hover { text-decoration: underline; }
  .nav-gh { font-size: 12px; color: #f5f5f7; opacity: 0.8; }
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; }

  .detail-header { background: var(--black); padding: 3rem 0 2.5rem; }
  .detail-header h1 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 40px; font-weight: 600; color: var(--white); line-height: 1.1; letter-spacing: -0.5px; margin-bottom: 0.5rem; }
  .detail-tagline { font-size: 17px; color: rgba(255,255,255,0.55); letter-spacing: -0.374px; }

  .usage { background: var(--black); padding: 0 0 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .usage-grid { display: flex; gap: 2rem; align-items: flex-start; }
  .usage-cmd { flex: 1; }
  .cmd-box { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; gap: 12px; position: relative; }
  .cmd-box code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; color: #e0e0e0; word-break: break-all; flex: 1; }
  .copy-btn { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 4px; transition: color 0.2s; flex-shrink: 0; }
  .copy-btn:hover { color: var(--white); }
  .cmd-help { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 0.5rem; letter-spacing: -0.12px; }
  .usage-info { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 4px; }
  .info-badge { font-size: 12px; color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.15); border-radius: 4px; padding: 4px 10px; letter-spacing: -0.12px; }

  .preview-section { background: var(--light-bg); padding: 3rem 0 4rem; }
  .tabs-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .tabs-bar h2 { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size: 28px; font-weight: 600; color: var(--near-black); }
  .tabs { display: flex; border: 1px solid rgba(0,0,0,0.15); border-radius: 8px; overflow: hidden; }
  .tab { padding: 6px 18px; font-size: 14px; font-family: inherit; letter-spacing: -0.224px; border: none; background: transparent; color: var(--text-80); cursor: pointer; transition: all 0.2s; }
  .tab.active { background: var(--near-black); color: var(--white); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* Slides grid */
  .slides-grid { display: flex; flex-direction: column; gap: 1rem; }
  .slide-label { font-size: 12px; font-weight: 600; color: var(--text-48); letter-spacing: 0.5px; text-transform: uppercase; margin-top: 1rem; }
  .slide-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }

  /* Base slide */
  .s { width: 100%; aspect-ratio: 16/9; position: relative; overflow: hidden; }
  .tk-s { background: #0A0A0A; font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif; }

  /* Cover */
  .tk-cover { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 8%; gap: 2%; }
  .tk-cover-intro { font-size: clamp(7px, 1.2vw, 14px); color: #888888; letter-spacing: 0.5px; }
  .tk-cover-hero { font-size: clamp(24px, 5.5vw, 56px); font-weight: 700; color: #FFFFFF; letter-spacing: -1px; }
  .tk-cover-sub { font-size: clamp(7px, 1.1vw, 13px); color: #888888; margin-top: 0.5%; }
  .tk-cover-ctas { display: flex; gap: 3%; margin-top: 3%; }
  .tk-pill { font-size: clamp(6px, 0.9vw, 11px); padding: 1.2% 3.5%; border-radius: 999px; letter-spacing: -0.1px; }
  .tk-pill-outline { color: #FFFFFF; border: 1px solid rgba(255,255,255,0.4); }
  .tk-pill-filled { color: #FFFFFF; background: #0A84FF; }

  /* Statement */
  .tk-statement { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 10%; text-align: center; }
  .tk-statement-text { font-size: clamp(16px, 4vw, 44px); font-weight: 700; color: #FFFFFF; letter-spacing: -0.5px; line-height: 1.15; }
  .tk-statement-sub { font-size: clamp(6px, 1vw, 12px); color: #888888; margin-top: 3%; max-width: 70%; }

  /* Big Number */
  .tk-bignum { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 8%; }
  .tk-bignum-value { font-size: clamp(36px, 9vw, 96px); font-weight: 700; color: #FFFFFF; letter-spacing: -2px; line-height: 1; }
  .tk-bignum-label { font-size: clamp(7px, 1.2vw, 14px); color: #888888; margin-top: 2%; letter-spacing: 0.3px; }
  .tk-bignum-delta { font-size: clamp(6px, 1vw, 12px); color: #30D158; margin-top: 1.5%; }

  /* Code */
  .tk-code-slide { display: flex; flex-direction: column; height: 100%; padding: 5% 6%; }
  .tk-code-title { font-size: clamp(12px, 2.6vw, 28px); font-weight: 600; color: #FFFFFF; margin-bottom: 3%; letter-spacing: -0.3px; }
  .tk-code-card { background: #141414; border-radius: 8px; padding: 4% 5%; flex: 1; display: flex; align-items: flex-start; border: 1px solid rgba(255,255,255,0.06); }
  .tk-code-block { font-family: 'SF Mono', Consolas, 'Courier New', monospace; font-size: clamp(5px, 0.9vw, 11px); color: #E0E0E0; line-height: 1.7; margin: 0; white-space: pre; }
  .tk-kw { color: #BF5AF2; }
  .tk-var { color: #FFFFFF; }
  .tk-op { color: #888888; }
  .tk-fn { color: #0A84FF; }
  .tk-str { color: #30D158; }
  .tk-key { color: #E0E0E0; }

  /* Inner layout (palette / typography) */
  .tk-inner { padding: 5% 6% 4%; height: 100%; display: flex; flex-direction: column; }
  .tk-section-title { font-size: clamp(12px, 2.6vw, 28px); font-weight: 600; color: #FFFFFF; letter-spacing: -0.3px; margin-bottom: 3%; }

  /* Palette */
  .tk-palette { display: flex; flex-wrap: wrap; gap: 2%; }
  .tk-swatch { display: flex; flex-direction: column; align-items: center; width: 9%; }
  .tk-swatch-block { width: 100%; aspect-ratio: 1; border-radius: 6px; border: 1px solid rgba(255,255,255,0.12); }
  .tk-swatch-name { font-size: clamp(4px, 0.6vw, 7px); color: #888888; text-align: center; margin-top: 6px; line-height: 1.3; }

  /* Typography */
  .tk-type-samples { display: flex; flex-direction: column; gap: 3%; flex: 1; }
  .tk-type-row { display: flex; justify-content: space-between; align-items: baseline; padding: 1.8% 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .tk-type-demo { flex: 1; }
  .tk-type-meta { font-size: clamp(4px, 0.6vw, 7px); color: #888888; flex-shrink: 0; margin-left: 4%; }

  /* DESIGN.md frame */
  .md-frame { border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; background: #fff; padding: 2rem 2.5rem; }
  .md-body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif; font-size: 15px; color: #1d1d1f; line-height: 1.6; }
  .md-body h1 { font-size: 28px; font-weight: 600; margin: 2rem 0 1rem; border-bottom: 1px solid #e5e7f0; padding-bottom: 0.5rem; }
  .md-body h2 { font-size: 22px; font-weight: 600; margin: 2rem 0 0.75rem; }
  .md-body h3 { font-size: 17px; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .md-body p { margin: 0.75rem 0; }
  .md-body ul, .md-body ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .md-body li { margin: 0.25rem 0; }
  .md-body code { font-family: 'SF Mono','Consolas',monospace; font-size: 13px; background: #f5f5f7; padding: 2px 6px; border-radius: 4px; }
  .md-body pre { background: #1d1d1f; color: #e0e0e0; padding: 1rem 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
  .md-body pre code { background: none; padding: 0; color: inherit; }
  .md-body table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 14px; }
  .md-body th { text-align: left; font-weight: 600; padding: 8px 12px; border-bottom: 2px solid #e5e7f0; }
  .md-body td { padding: 8px 12px; border-bottom: 1px solid #e5e7f0; }
  .md-body hr { border: none; border-top: 1px solid #e5e7f0; margin: 2rem 0; }
  .md-body blockquote { border-left: 3px solid #0071e3; margin: 1rem 0; padding: 0.5rem 1rem; background: #f5f5f7; border-radius: 0 4px 4px 0; }

  footer { background: var(--light-bg); padding: 2rem 0; text-align: center; border-top: 1px solid rgba(0,0,0,0.06); }
  footer p { font-size: 12px; color: var(--text-48); }

  @media (max-width: 834px) {
    .usage-grid { flex-direction: column; }
    .detail-header h1 { font-size: 32px; }
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const target = (btn as HTMLElement).dataset.tab;
      document.getElementById('tab-' + target)?.classList.add('active');
    });
  });
  // Copy button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text);
      btn.innerHTML = '<span style="font-size:12px;color:#30D158;">Copied!</span>';
      setTimeout(() => {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/></svg>';
      }, 1500);
    });
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import designs from '../data/designs.json';

const categories = [...new Set(designs.map(d => d.category))];
---

<Layout title="slide-design-md — Slide Design Systems for AI Agents">
  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <span class="nav-logo">slide-design-md</span>
      <div class="nav-links">
        <a href="#browse">Browse</a>
        <a href="https://github.com/takumaoshiro/slide-design-md" target="_blank">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Hero: Dark section -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">{designs.length} design systems</p>
      <h1 class="hero-title">Slide design systems<br />for AI agents.</h1>
      <p class="hero-sub">
        Drop a <code>DESIGN.md</code> into your project.<br />
        AI generates on-brand presentations automatically.
      </p>
      <div class="hero-cta">
        <a href="#browse" class="btn-pill-outline">Browse designs</a>
        <a href="https://github.com/takumaoshiro/slide-design-md/blob/main/designs/_template/DESIGN.md" class="btn-pill-blue" target="_blank">Get started</a>
      </div>
    </div>
  </section>

  <!-- How it works: Light section -->
  <section class="how-section">
    <div class="container">
      <h2 class="section-heading">How it works.</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Browse</h3>
          <p>Find a slide design system that fits your presentation needs.</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Copy</h3>
          <p>Add the <code>DESIGN.md</code> file to your project repository.</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Generate</h3>
          <p>AI agents read the spec and produce visually consistent slides.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Catalog: Dark section -->
  <section id="browse" class="catalog">
    <div class="container">
      <h2 class="section-heading-light">Design Systems</h2>
      <div class="filters">
        <button class="filter active" data-category="all">All</button>
        {categories.map(cat => (
          <button class="filter" data-category={cat}>{cat}</button>
        ))}
      </div>
      <div class="grid">

        {/* ── CA ADVANCE ── */}
        <a href="/slide-design-md/designs/ca-advance/"
           class="card" data-category="Corporate">
          <div class="preview">
            <div class="slide ca-advance-slide">
              <div class="ca-topline"></div>
              <div class="ca-cover-body">
                <div class="ca-logo">CA ADVANCE</div>
                <div class="ca-title">Monthly Performance Report</div>
                <div class="ca-divider"></div>
                <div class="ca-date">2025.04 — Executive Summary</div>
              </div>
            </div>
          </div>
          <div class="card-info">
            <h3>CA ADVANCE</h3>
            <p class="card-desc">White-base, professional, information-dense corporate reporting.</p>
            <div class="card-meta">
              <span class="card-style">Minimal BtoB</span>
              <span class="card-ratio">16:9</span>
              <span class="card-arrow">Learn more &rsaquo;</span>
            </div>
          </div>
        </a>

        {/* ── Tech Keynote ── */}
        <a href="/slide-design-md/designs/tech-keynote/"
           class="card" data-category="Tech">
          <div class="preview">
            <div class="slide tk-slide">
              <div class="tk-center">
                <div class="tk-hero-text">Introducing</div>
                <div class="tk-product">Product X</div>
                <div class="tk-sub">The most advanced platform we've ever created.</div>
                <div class="tk-ctas">
                  <span class="tk-btn-outline">Learn more</span>
                  <span class="tk-btn-blue">Get started</span>
                </div>
              </div>
            </div>
          </div>
          <div class="card-info">
            <h3>Tech Keynote</h3>
            <p class="card-desc">Dark, bold, Apple-inspired. High-impact keynote for launches and tech talks.</p>
            <div class="card-meta">
              <span class="card-style">Dark Keynote</span>
              <span class="card-ratio">16:9</span>
              <span class="card-arrow">Learn more &rsaquo;</span>
            </div>
          </div>
        </a>

        {/* ── Startup Pitch ── */}
        <a href="/slide-design-md/designs/startup-pitch/"
           class="card" data-category="Startup">
          <div class="preview">
            <div class="slide sp-slide">
              <div class="sp-content">
                <div class="sp-badge">Series A</div>
                <div class="sp-title">Company Name</div>
                <div class="sp-tagline">The future of enterprise collaboration.</div>
                <div class="sp-metrics">
                  <div class="sp-metric">
                    <span class="sp-num">$4.2M</span>
                    <span class="sp-label">ARR</span>
                  </div>
                  <div class="sp-metric">
                    <span class="sp-num">312%</span>
                    <span class="sp-label">YoY Growth</span>
                  </div>
                  <div class="sp-metric">
                    <span class="sp-num">1,200</span>
                    <span class="sp-label">Customers</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="card-info">
            <h3>Startup Pitch</h3>
            <p class="card-desc">Modern gradient, investor-facing. Clean pitch decks for fundraising.</p>
            <div class="card-meta">
              <span class="card-style">Modern Pitch</span>
              <span class="card-ratio">16:9</span>
              <span class="card-arrow">Learn more &rsaquo;</span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- CTA: Light section -->
  <section class="cta-section">
    <div class="container">
      <h2 class="section-heading">Add your design system.</h2>
      <p class="cta-body">Copy the template. Define your visual identity. Submit a PR.</p>
      <div class="cta-links">
        <a href="https://github.com/takumaoshiro/slide-design-md/blob/main/designs/_template/DESIGN.md" class="btn-pill-outline-dark" target="_blank">
          View template &rsaquo;
        </a>
        <a href="https://github.com/takumaoshiro/slide-design-md" class="link-blue" target="_blank">
          GitHub repository &rsaquo;
        </a>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p>slide-design-md &mdash; Built for AI agents that create presentations.</p>
    </div>
  </footer>
</Layout>

<style>
  /* ── Nav (Apple glass) ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    height: 48px;
  }
  .nav-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-size: 14px;
    font-weight: 600;
    color: #f5f5f7;
    letter-spacing: -0.224px;
  }
  .nav-links { display: flex; gap: 2rem; }
  .nav-links a {
    font-size: 12px;
    color: #f5f5f7;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .nav-links a:hover { opacity: 1; }

  /* ── Container ── */
  .container {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero (Dark) ── */
  .hero {
    background: var(--black);
    padding: 8rem 0 6rem;
    text-align: center;
  }
  .hero-eyebrow {
    font-size: 14px;
    color: #2997ff;
    letter-spacing: -0.224px;
    margin-bottom: 1rem;
  }
  .hero-title {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    font-size: 56px;
    font-weight: 600;
    line-height: 1.07;
    letter-spacing: -0.5px;
    color: var(--white);
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: 21px;
    line-height: 1.38;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 2.5rem;
  }
  .hero-sub code {
    font-family: 'SF Mono', 'Consolas', monospace;
    font-size: 19px;
    color: var(--white);
    background: rgba(255, 255, 255, 0.08);
    padding: 2px 10px;
    border-radius: 5px;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .btn-pill-outline {
    padding: 8px 22px;
    border-radius: 980px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: var(--white);
    font-size: 17px;
    letter-spacing: -0.374px;
    transition: all 0.2s;
  }
  .btn-pill-outline:hover {
    border-color: var(--white);
    background: rgba(255, 255, 255, 0.08);
  }
  .btn-pill-blue {
    padding: 8px 22px;
    border-radius: 980px;
    background: var(--blue);
    color: var(--white);
    font-size: 17px;
    letter-spacing: -0.374px;
    transition: opacity 0.2s;
  }
  .btn-pill-blue:hover { opacity: 0.85; }

  /* ── How Section (Light) ── */
  .how-section {
    background: var(--light-bg);
    padding: 5rem 0;
  }
  .section-heading {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    font-size: 40px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.5px;
    color: var(--near-black);
    text-align: center;
    margin-bottom: 3rem;
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .step { text-align: center; padding: 2rem 1.5rem; }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--near-black);
    color: var(--white);
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }
  .step h3 {
    font-size: 21px;
    font-weight: 600;
    color: var(--near-black);
    margin-bottom: 0.5rem;
  }
  .step p {
    font-size: 14px;
    color: var(--text-80);
    letter-spacing: -0.224px;
    line-height: 1.43;
  }
  .step code {
    font-family: 'SF Mono', 'Consolas', monospace;
    font-size: 13px;
    background: rgba(0, 0, 0, 0.06);
    padding: 1px 6px;
    border-radius: 4px;
  }

  /* ── Catalog (Dark) ── */
  .catalog {
    background: var(--black);
    padding: 5rem 0 6rem;
  }
  .section-heading-light {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    font-size: 40px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.5px;
    color: var(--white);
    text-align: center;
    margin-bottom: 2rem;
  }
  .filters {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 3rem;
  }
  .filter {
    padding: 6px 16px;
    border-radius: 980px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: rgba(255, 255, 255, 0.55);
    font-size: 14px;
    font-family: inherit;
    letter-spacing: -0.224px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: rgba(255, 255, 255, 0.8);
  }
  .filter.active {
    background: var(--white);
    border-color: var(--white);
    color: var(--near-black);
  }

  /* ── Cards Grid ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .card {
    background: #1d1d1f;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .card:hover {
    transform: scale(1.02);
    box-shadow: rgba(0, 0, 0, 0.22) 3px 5px 30px 0px;
  }

  /* ── Slide Preview (shared) ── */
  .preview {
    padding: 1.25rem 1.25rem 0.5rem;
  }
  .slide {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }

  /* ── CA ADVANCE slide ── */
  .ca-advance-slide {
    background: #FFFFFF;
    display: flex;
    flex-direction: column;
  }
  .ca-topline {
    height: 2px;
    background: #1B4F8A;
  }
  .ca-cover-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8%;
    gap: 4%;
  }
  .ca-logo {
    font-size: clamp(6px, 1.4vw, 11px);
    font-weight: 700;
    color: #1B4F8A;
    letter-spacing: 0.5px;
  }
  .ca-title {
    font-family: 'Arial Black', Arial, sans-serif;
    font-size: clamp(10px, 2.8vw, 22px);
    font-weight: 900;
    color: #1A1A1A;
    text-align: center;
    line-height: 1.2;
  }
  .ca-divider {
    width: 15%;
    height: 2px;
    background: #1B4F8A;
  }
  .ca-date {
    font-size: clamp(5px, 1.1vw, 9px);
    color: #999999;
    letter-spacing: 0.3px;
  }

  /* ── Tech Keynote slide ── */
  .tk-slide {
    background: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tk-center {
    text-align: center;
    padding: 8%;
  }
  .tk-hero-text {
    font-size: clamp(5px, 1.1vw, 9px);
    color: #888888;
    letter-spacing: 0.3px;
    margin-bottom: 4%;
  }
  .tk-product {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    font-size: clamp(14px, 3.5vw, 28px);
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1.07;
    letter-spacing: -0.5px;
    margin-bottom: 4%;
  }
  .tk-sub {
    font-size: clamp(5px, 1.2vw, 10px);
    color: #888888;
    margin-bottom: 8%;
    line-height: 1.3;
  }
  .tk-ctas {
    display: flex;
    gap: 6%;
    justify-content: center;
  }
  .tk-btn-outline {
    font-size: clamp(4px, 0.9vw, 8px);
    color: #FFFFFF;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 980px;
    padding: 2px 10px;
  }
  .tk-btn-blue {
    font-size: clamp(4px, 0.9vw, 8px);
    color: #FFFFFF;
    background: #0A84FF;
    border-radius: 980px;
    padding: 2px 10px;
  }

  /* ── Startup Pitch slide ── */
  .sp-slide {
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sp-content {
    text-align: center;
    padding: 8%;
  }
  .sp-badge {
    display: inline-block;
    font-size: clamp(4px, 0.8vw, 7px);
    color: #6366F1;
    background: #EEF2FF;
    padding: 1px 8px;
    border-radius: 980px;
    margin-bottom: 5%;
    font-weight: 500;
  }
  .sp-title {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(12px, 3vw, 24px);
    font-weight: 700;
    color: #1A1A2E;
    line-height: 1.1;
    margin-bottom: 3%;
  }
  .sp-tagline {
    font-size: clamp(5px, 1.1vw, 9px);
    color: #9393A8;
    margin-bottom: 8%;
  }
  .sp-metrics {
    display: flex;
    gap: 6%;
    justify-content: center;
  }
  .sp-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #F8F9FC;
    border: 1px solid #E5E7F0;
    border-radius: 6px;
    padding: 4% 5%;
  }
  .sp-num {
    font-size: clamp(8px, 1.8vw, 15px);
    font-weight: 700;
    color: #6366F1;
    line-height: 1.2;
  }
  .sp-label {
    font-size: clamp(3px, 0.7vw, 6px);
    color: #9393A8;
    margin-top: 2px;
  }

  /* ── Card Info ── */
  .card-info {
    padding: 1rem 1.5rem 1.25rem;
  }
  .card-info h3 {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    font-size: 21px;
    font-weight: 600;
    color: var(--white);
    letter-spacing: 0.1px;
    line-height: 1.19;
    margin-bottom: 0.35rem;
  }
  .card-desc {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: -0.224px;
    line-height: 1.43;
    margin-bottom: 0.75rem;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 12px;
    letter-spacing: -0.12px;
  }
  .card-style { color: rgba(255, 255, 255, 0.35); }
  .card-ratio {
    color: rgba(255, 255, 255, 0.35);
    padding: 2px 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
  }
  .card-arrow {
    margin-left: auto;
    color: #2997ff;
    font-size: 14px;
    letter-spacing: -0.224px;
  }

  /* ── CTA Section (Light) ── */
  .cta-section {
    background: var(--light-bg);
    padding: 5rem 0;
    text-align: center;
  }
  .cta-body {
    font-size: 21px;
    color: var(--text-80);
    margin-bottom: 2rem;
  }
  .cta-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    align-items: center;
  }
  .btn-pill-outline-dark {
    padding: 8px 22px;
    border-radius: 980px;
    border: 1px solid var(--near-black);
    color: var(--near-black);
    font-size: 17px;
    letter-spacing: -0.374px;
    transition: all 0.2s;
  }
  .btn-pill-outline-dark:hover {
    background: var(--near-black);
    color: var(--white);
  }
  .link-blue {
    color: var(--blue-link);
    font-size: 17px;
    letter-spacing: -0.374px;
  }
  .link-blue:hover { text-decoration: underline; }

  /* ── Footer ── */
  footer {
    background: var(--light-bg);
    padding: 2rem 0;
    text-align: center;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }
  footer p {
    font-size: 12px;
    color: var(--text-48);
    letter-spacing: -0.12px;
  }

  /* ── Responsive ── */
  @media (max-width: 834px) {
    .hero-title { font-size: 40px; }
    .hero-sub { font-size: 17px; }
    .section-heading, .section-heading-light { font-size: 32px; }
    .steps { grid-template-columns: 1fr; gap: 0; }
    .grid { grid-template-columns: 1fr; }
    .hero-cta, .cta-links { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: 32px; }
    .hero { padding: 5rem 0 4rem; }
  }
</style>

<script>
  document.querySelectorAll('.filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.category;
      document.querySelectorAll('.card').forEach(card => {
        if (cat === 'all' || (card as HTMLElement).dataset.category === cat) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

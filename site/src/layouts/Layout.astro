---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Slide design system inspirations for AI agents" />
    <title>{title}</title>
    <style is:global>
      :root {
        --black: #000000;
        --near-black: #1d1d1f;
        --light-bg: #f5f5f7;
        --white: #ffffff;
        --blue: #0071e3;
        --blue-link: #0066cc;
        --blue-bright: #2997ff;
        --text-80: rgba(0, 0, 0, 0.8);
        --text-48: rgba(0, 0, 0, 0.48);
        --dark-surface: #1d1d1f;
        --nav-bg: rgba(0, 0, 0, 0.8);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background: var(--white);
        color: var(--near-black);
        line-height: 1.47;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <!-- Password Gate -->
    <div id="auth-gate">
      <div class="auth-box">
        <h1 class="auth-title">slide-design-md</h1>
        <p class="auth-sub">Slide design systems for AI agents.</p>
        <form id="auth-form">
          <input type="password" id="auth-input" placeholder="Enter password" autocomplete="off" />
          <button type="submit">Continue</button>
        </form>
        <p id="auth-error" class="auth-error"></p>
      </div>
    </div>

    <!-- Main Content -->
    <div id="main-content" style="display:none;">
      <slot />
    </div>

    <style is:global>
      #auth-gate {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: var(--black);
      }
      .auth-box {
        text-align: center;
        max-width: 380px;
        padding: 2rem;
      }
      .auth-title {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', Helvetica, Arial, sans-serif;
        font-size: 40px;
        font-weight: 600;
        line-height: 1.1;
        letter-spacing: -0.5px;
        color: var(--white);
        margin-bottom: 0.5rem;
      }
      .auth-sub {
        color: rgba(255, 255, 255, 0.5);
        font-size: 17px;
        font-weight: 400;
        letter-spacing: -0.374px;
        margin-bottom: 2rem;
      }
      #auth-form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      #auth-input {
        padding: 12px 16px;
        border-radius: 12px;
        border: none;
        background: rgba(255, 255, 255, 0.1);
        color: var(--white);
        font-size: 17px;
        font-family: inherit;
        letter-spacing: -0.374px;
        outline: none;
        transition: background 0.2s;
        text-align: center;
      }
      #auth-input:focus {
        background: rgba(255, 255, 255, 0.15);
        outline: 2px solid var(--blue);
        outline-offset: 2px;
      }
      #auth-input::placeholder {
        color: rgba(255, 255, 255, 0.35);
      }
      #auth-form button {
        padding: 12px 24px;
        border-radius: 980px;
        border: none;
        background: var(--blue);
        color: var(--white);
        font-size: 17px;
        font-weight: 400;
        font-family: inherit;
        letter-spacing: -0.374px;
        cursor: pointer;
        transition: opacity 0.2s;
      }
      #auth-form button:hover { opacity: 0.85; }
      .auth-error {
        color: #ff453a;
        font-size: 14px;
        margin-top: 0.75rem;
        min-height: 1.2em;
        letter-spacing: -0.224px;
      }
    </style>

    <script is:inline>
      const PASS_HASH = 'fb18c395142dabb9f4c9c33ff9a82ac66baf7618b7572806f19e50c1cf9b1b04';
      async function sha256(message) {
        const msgBuffer = new TextEncoder().encode(message);
        const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
      }
      function unlock() {
        document.getElementById('auth-gate').style.display = 'none';
        document.getElementById('main-content').style.display = '';
      }
      if (sessionStorage.getItem('sdm-auth') === 'true') { unlock(); }
      document.getElementById('auth-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const input = document.getElementById('auth-input').value;
        const hash = await sha256(input);
        if (hash === PASS_HASH) {
          sessionStorage.setItem('sdm-auth', 'true');
          unlock();
        } else {
          document.getElementById('auth-error').textContent = 'Incorrect password';
          document.getElementById('auth-input').value = '';
          document.getElementById('auth-input').focus();
        }
      });
    </script>
  </body>
</html>
